{% extends "home.twig" %}

{% block content %}
<div class="bg-slate-50 pt-12 pb-20" x-data="{ search: '' }">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        {# Header #}
        <div class="text-center mb-12">
            <span class="inline-flex items-center rounded-md bg-indigo-50 px-2.5 py-1 text-xs font-medium text-indigo-700 ring-1 ring-inset ring-indigo-700/10 mb-4">
                {{ posts|length }} artiklar
            </span>
            <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-5xl mb-4">
                {% if current_category is defined %}
                    {{ current_category }}
                {% else %}
                    Blogg & Guider
                {% endif %}
            </h1>
            <p class="text-lg text-slate-600 max-w-2xl mx-auto">
                Lär dig mer om lön, karriär och arbetsmarknad. Sök bland våra guider och artiklar.
            </p>
        </div>

        {# Search/Filter #}
        <div class="max-w-xl mx-auto mb-10">
            <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                </div>
                <input type="text" x-model="search" placeholder="Sök artikel (t.ex. Förhandling)..." class="block w-full rounded-xl border-0 py-3 pl-10 pr-4 text-slate-900 ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 bg-white shadow-sm">
            </div>
        </div>

        {# Categories / Breadcrumb-ish links if needed, otherwise clean grid #}
        {% if current_category is defined %}
        <div class="mb-8 text-center">
            <a href="/blogg" class="text-sm font-medium text-indigo-600 hover:text-indigo-500 flex items-center justify-center gap-1">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                Visa alla artiklar
            </a>
        </div>
        {% endif %}

        {# Posts Grid #}
        {% if posts is empty %}
            <div class="text-center py-16 bg-white rounded-2xl shadow-sm ring-1 ring-slate-900/5">
                <svg class="w-16 h-16 mx-auto text-slate-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path>
                </svg>
                <p class="text-slate-600">Inga artiklar hittades.</p>
            </div>
        {% else %}
            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
                {% for post in posts %}
                <a href="/blogg/{{ post.slug }}" 
                   class="group relative flex flex-col rounded-xl bg-white shadow-sm ring-1 ring-slate-900/5 hover:shadow-lg hover:ring-indigo-600/20 transition-all overflow-hidden"
                   x-show="'{{ post.title|lower }}'.includes(search.toLowerCase()) || search === ''">
                    
                    {# Featured Image #}
                    <div class="aspect-square w-full bg-indigo-50 relative overflow-hidden">
                         {% if post.image is defined %}
                            <img src="{{ post.image }}" alt="" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
                         {% else %}
                            <div class="w-full h-full flex items-center justify-center text-indigo-200">
                                <svg class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                                </svg>
                            </div>
                         {% endif %}
                    </div>

                    <div class="flex-1 p-5 flex flex-col">
                        <div class="flex items-center gap-2 mb-3">
                             {% if post.category is defined %}
                            <span class="inline-flex items-center rounded-md bg-indigo-50 px-2 py-1 text-xs font-medium text-indigo-700 ring-1 ring-inset ring-indigo-700/10">
                                {{ post.category }}
                            </span>
                             {% endif %}
                             {% if post.date is defined %}
                            <span class="text-xs text-slate-500">{{ post.formatted_date }}</span>
                             {% endif %}
                        </div>

                        <h2 class="text-base font-bold text-slate-900 group-hover:text-indigo-600 transition-colors line-clamp-2 mb-2">
                            {{ post.title }}
                        </h2>
                        
                        <p class="text-sm text-slate-600 line-clamp-2 mb-4 flex-1">
                            {{ post.excerpt | default(post.description | default('')) }}
                        </p>

                        <div class="flex items-center text-sm font-medium text-indigo-600">
                            Läs artikel
                            <svg class="h-4 w-4 ml-1 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                            </svg>
                        </div>
                    </div>
                </a>
                {% endfor %}
            </div>
        {% endif %}

        {# CTA / Stats Box (Optional, keeping it simple for now or matching yrken) #}
        <div class="mt-16 bg-white rounded-2xl shadow-sm ring-1 ring-slate-900/5 p-8 text-center">
            <h2 class="text-xl font-bold text-slate-900 mb-4"> Vill du veta vad du borde tjäna?</h2>
             <p class="text-slate-600 mb-8 max-w-2xl mx-auto">
                Använd vår lönestatistik och kalkylator för att se om du ligger rätt i löneligan.
            </p>
            <a href="/" class="inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition-colors">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                </svg>
                Räkna ut din lön
            </a>
        </div>

    </div>
</div>
{% endblock %}
