<!DOCTYPE html>
<html lang="sv" class="h-full bg-slate-50 antialiased">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <meta name="description" content="{{ description|default('Räkna ut din lön efter skatt med Sveriges enklaste lönekalkylator. Se nettolön, skatter och arbetsgivaravgifter för inkomståret 2026.') }}">
    <link rel="canonical" href="https://raknalon.se{{ current_path|default('') }}">
    
    <!-- Open Graph -->
    <meta property="og:title" content="{{ title }}">
    <meta property="og:description" content="{{ description|default('Räkna ut din lön efter skatt med Sveriges enklaste lönekalkylator.') }}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://raknalon.se{{ current_path|default('') }}">
    <meta property="og:image" content="https://raknalon.se/img/og-image.jpg">
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/img/favicon.png">
    
    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1826806205536778"
     crossorigin="anonymous"></script>
    
    <!-- Schema.org Structured Data -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "WebApplication",
        "name": "Raknalon.se Lönekalkylator",
        "url": "https://raknalon.se",
        "description": "Räkna ut din lön efter skatt med Sveriges enklaste lönekalkylator. Se nettolön, skatter och arbetsgivaravgifter för inkomståret 2026.",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "All",
        "offers": {
            "@type": "Offer",
            "price": "0",
            "priceCurrency": "SEK"
        },
        "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "4.8",
            "reviewCount": "127"
        }
    }
    </script>
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
            {
                "@type": "Question",
                "name": "Hur räknar man ut lön efter skatt?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Nettolönen beräknas genom att dra av kommunalskatt och eventuell statlig inkomstskatt från bruttolönen. Jobbskatteavdraget sänker den totala skatten. Använd vår kalkylator för exakt beräkning baserat på din kommun."
                }
            },
            {
                "@type": "Question",
                "name": "Vad är skillnaden mellan brutto och netto?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Bruttolön är lönen innan skatt, alltså det som står i ditt anställningsavtal. Nettolön är det belopp som faktiskt betalas ut till dig efter att skatten har dragits."
                }
            },
            {
                "@type": "Question",
                "name": "Hur mycket skatt betalar man i Sverige 2026?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Skatten varierar beroende på kommun (ca 29-35%). Den genomsnittliga kommunalskatten i Sverige är cirka 32.37%. Personer med hög inkomst (över 615 300 kr/år) betalar även statlig inkomstskatt på 20%."
                }
            }
        ]
    }
    </script>
    
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300..900&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS -->
    <link href="/css/app.css" rel="stylesheet">
    
    <!-- Scripts -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script src="/js/calculator.js"></script>
    
    {% block head_extra %}{% endblock %}
</head>
<body class="h-full flex flex-col">
    
    <!-- Navigation -->
    <header class="bg-white/80 backdrop-blur-md sticky top-0 z-50 border-b border-slate-200" x-data="{ mobileMenuOpen: false }">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
            <div class="flex h-16 justify-between items-center">
                <div class="flex items-center gap-2">
                    <a href="/" class="flex items-center gap-2 group">
                        <div class="bg-indigo-600 rounded-lg p-1.5 group-hover:bg-indigo-500 transition-colors">
                            <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                            </svg>
                        </div>
                        <span class="text-xl font-bold text-slate-900 tracking-tight">raknalon.se</span>
                    </a>
                </div>
                
                <!-- Desktop Navigation -->
                <nav class="hidden md:flex gap-6 text-sm font-medium text-slate-600">
                    <a href="/yrken" class="hover:text-indigo-600 transition-colors">Alla yrken</a>
                    <a href="/kommunal-lon" class="hover:text-indigo-600 transition-colors">Kommunal lön</a>
                    <a href="/blogg" class="hover:text-indigo-600 transition-colors">Blogg</a>
                    <a href="/brutto-netto" class="hover:text-indigo-600 transition-colors">Brutto vs Netto</a>
                    <a href="/jobbskatteavdrag" class="hover:text-indigo-600 transition-colors">Jobbskatteavdrag</a>
                </nav>
                
                <!-- Mobile Hamburger Button -->
                <button type="button" @click="mobileMenuOpen = !mobileMenuOpen" class="md:hidden p-2 rounded-md text-slate-600 hover:bg-slate-100 hover:text-slate-900 transition-colors" aria-label="Toggle menu">
                    <svg x-show="!mobileMenuOpen" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                    <svg x-show="mobileMenuOpen" x-cloak class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        </div>
        
        <!-- Mobile Menu Panel -->
        <div x-show="mobileMenuOpen" x-cloak x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 -translate-y-1" x-transition:enter-end="opacity-100 translate-y-0" x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100 translate-y-0" x-transition:leave-end="opacity-0 -translate-y-1" class="md:hidden border-t border-slate-200 bg-white">
            <div class="px-4 py-4 space-y-2">
                <a href="/yrken" class="block px-3 py-2 rounded-lg text-base font-medium text-slate-700 hover:bg-indigo-50 hover:text-indigo-600 transition-colors">Alla yrken</a>
                <a href="/kommunal-lon" class="block px-3 py-2 rounded-lg text-base font-medium text-slate-700 hover:bg-indigo-50 hover:text-indigo-600 transition-colors">Kommunal lön</a>
                <a href="/blogg" class="block px-3 py-2 rounded-lg text-base font-medium text-slate-700 hover:bg-indigo-50 hover:text-indigo-600 transition-colors">Blogg</a>
                <a href="/brutto-netto" class="block px-3 py-2 rounded-lg text-base font-medium text-slate-700 hover:bg-indigo-50 hover:text-indigo-600 transition-colors">Brutto vs Netto</a>
                <a href="/jobbskatteavdrag" class="block px-3 py-2 rounded-lg text-base font-medium text-slate-700 hover:bg-indigo-50 hover:text-indigo-600 transition-colors">Jobbskatteavdrag</a>
                <a href="/statlig-skatt" class="block px-3 py-2 rounded-lg text-base font-medium text-slate-700 hover:bg-indigo-50 hover:text-indigo-600 transition-colors">Statlig skatt</a>
            </div>
        </div>
    </header>


    <!-- Main Content -->
    <main class="flex-grow">
        {% block content %}
        <div class="relative isolate pt-14 pb-20 sm:pt-20 sm:pb-24">
            
            <!-- Background effects -->
            <div class="absolute inset-x-0 -top-40 -z-10 transform-gpu overflow-hidden blur-3xl sm:-top-80" aria-hidden="true">
                <div class="relative left-[calc(50%-11rem)] aspect-[1155/678] w-[36.125rem] -translate-x-1/2 rotate-[30deg] bg-gradient-to-tr from-[#ff80b5] to-[#9089fc] opacity-20 sm:left-[calc(50%-30rem)] sm:w-[72.1875rem]" style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)"></div>
            </div>

            <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
                <div class="mx-auto max-w-2xl text-center mb-12">
                    <div class="mb-6 flex justify-center">
                       <span class="relative rounded-full px-3 py-1 text-sm leading-6 text-indigo-600 ring-1 ring-inset ring-indigo-600/10 bg-indigo-50 font-medium">
                           Uppdaterad för inkomståret 2026
                       </span>
                    </div>
                    <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-6xl mb-6">
                        Räkna ut din <span class="text-indigo-600">lön efter skatt</span>
                    </h1>
                    <p class="text-lg leading-8 text-slate-600">
                        Enkel och korrekt lönekalkylator. Se exakt vad du får ut i handen baserat på din kommun och ålder.
                    </p>
                </div>

                <!-- Calculator Card -->
                <div class="mx-auto max-w-xl bg-white rounded-2xl shadow-xl shadow-indigo-900/5 ring-1 ring-slate-900/5 overflow-hidden" x-data="salaryCalculator()">
                    <div class="p-6 sm:p-8">
                        <form @submit.prevent="calculate" class="space-y-6">
                            <div>
                                <label for="salary" class="block text-sm font-semibold leading-6 text-slate-900">Månadslön (Brutto)</label>
                                <div class="relative mt-2 rounded-lg shadow-sm">
                                    <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                                        <span class="text-slate-500 sm:text-sm font-medium">kr</span>
                                    </div>
                                    <input type="number" id="salary" x-model="salary" 
                                        class="block w-full rounded-lg border-0 py-3.5 pl-10 text-slate-900 ring-1 ring-inset ring-slate-200 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-lg sm:leading-6 font-semibold transition-shadow" 
                                        placeholder="T.ex. 35 000">
                                </div>
                            </div>

                            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
                                <div>
                                    <label for="municipality" class="block text-sm font-semibold leading-6 text-slate-900">Kommun</label>
                                    <div class="mt-2">
                                        <select id="municipality" x-model="selectedMunicipality" @change="updateTaxRate"
                                            class="block w-full rounded-lg border-0 py-3 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-200 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6">
                                            <option value="">Välj kommun...</option>
                                            {% for kommun in municipalities %}
                                                <option value="{{ kommun.tax_rate }}">{{ kommun.name }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                    <div class="flex justify-between mt-1.5 px-1">
                                         <p class="text-xs text-slate-500">Påverkar skattesatsen</p>
                                         <p class="text-xs font-medium text-indigo-600" x-show="selectedMunicipality" x-text="taxRate + '%'"></p>
                                    </div>
                                </div>

                                <div>
                                    <label for="age" class="block text-sm font-semibold leading-6 text-slate-900">Ålder</label>
                                    <div class="mt-2">
                                        <input type="number" id="age" x-model="age"
                                            class="block w-full rounded-lg border-0 py-3 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-200 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6"
                                            placeholder="30">
                                    </div>
                                    <p class="mt-1.5 px-1 text-xs text-slate-500">Påverkar jobbskatteavdraget</p>
                                </div>
                            </div>

                            <button type="submit" 
                                :disabled="loading"
                                :class="{'opacity-80 cursor-wait': loading, 'hover:bg-indigo-500': !loading}"
                                class="w-full rounded-lg bg-indigo-600 px-4 py-4 text-sm font-bold text-white shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-all flex justify-center items-center gap-2">
                                <span x-show="!loading">Beräkna lön</span>
                                <span x-show="loading">Räknar...</span>
                                <svg x-show="!loading" class="w-4 h-4 text-indigo-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                            </button>
                        </form>

                        <!-- Results -->
                        <div x-show="result" x-transition.opacity.duration.300ms class="mt-8 pt-8 border-t border-slate-100">
                             <div class="text-center bg-indigo-50/50 rounded-xl p-6 border border-indigo-100">
                                <p class="text-xs font-bold text-indigo-600 uppercase tracking-widest mb-1">Nettolön</p>
                                <p class="text-4xl sm:text-5xl font-extrabold text-slate-900 tracking-tight" x-text="formatMoney(result?.net_salary)"></p>
                                <p class="text-sm text-slate-500 mt-2 font-medium">Kronor kvar efter skatt</p>
                             </div>

                             <div class="mt-6 space-y-3">
                                <div class="flex justify-between items-center p-3 rounded-lg hover:bg-slate-50 transition-colors">
                                    <span class="text-sm font-medium text-slate-600">Total skatt</span>
                                    <span class="text-sm font-bold text-slate-900" x-text="formatMoney(result?.total_tax) + ' kr'"></span>
                                </div>
                                <div class="flex justify-between items-center p-3 rounded-lg hover:bg-slate-50 transition-colors">
                                    <span class="text-sm font-medium text-slate-600">Arbetsgivaravgift</span>
                                    <span class="text-sm font-bold text-slate-900" x-text="formatMoney(result?.employer_cost) + ' kr'"></span>
                                </div>
                             </div>
                        </div>
                    </div>
                </div>

                <!-- Trust Indicators -->
                <div class="mt-16 grid grid-cols-1 gap-8 sm:grid-cols-3 text-center">
                    <div class="flex flex-col items-center">
                        <div class="rounded-full bg-indigo-100 p-3 mb-4">
                            <svg class="h-6 w-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        </div>
                        <h3 class="text-sm font-bold text-slate-900">Senaste skattetabellerna</h3>
                        <p class="mt-1 text-sm text-slate-500">Alltid uppdaterad med Skatteverkets data för 2026.</p>
                    </div>
                    <div class="flex flex-col items-center">
                         <div class="rounded-full bg-indigo-100 p-3 mb-4">
                            <svg class="h-6 w-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
                        </div>
                        <h3 class="text-sm font-bold text-slate-900">Alla 290 kommuner</h3>
                        <p class="mt-1 text-sm text-slate-500">Exakt uträkning baserat på din lokala skattesats.</p>
                    </div>
                    <div class="flex flex-col items-center">
                        <div class="rounded-full bg-indigo-100 p-3 mb-4">
                            <svg class="h-6 w-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                        </div>
                        <h3 class="text-sm font-bold text-slate-900">Blixtsnabb</h3>
                        <p class="mt-1 text-sm text-slate-500">Inga laddtider. Få svar direkt på skärmen.</p>
                    </div>
                </div>
            </div>
            
            <!-- Popular Professions Section -->
            {% if popular_professions %}
            <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 mt-24">
                <div class="relative">
                    <div class="absolute inset-0 flex items-center" aria-hidden="true">
                        <div class="w-full border-t border-slate-200"></div>
                    </div>
                    <div class="relative flex justify-center">
                        <span class="bg-slate-50 px-3 text-base font-semibold leading-6 text-slate-900">Populära yrken 2026</span>
                    </div>
                </div>
                <div class="mx-auto mt-10 grid max-w-2xl grid-cols-2 gap-x-8 gap-y-12 sm:grid-cols-3 lg:grid-cols-4 lg:max-w-none">
                    {% for p in popular_professions %}
                    <div class="relative">
                        <h3 class="text-sm font-semibold leading-6 text-slate-900">
                            <a href="/lon/{{ p.slug }}" class="hover:text-indigo-600 transition-colors">
                                {{ p.title }}
                            </a>
                        </h3>
                        <p class="mt-1 text-xs text-slate-500">{{ p.median_salary|number_format(0, ',', ' ') }} kr/mån</p>
                    </div>
                    {% endfor %}
                </div>
                 <div class="mt-8 text-center">
                    <a href="/yrken" class="text-sm font-semibold text-indigo-600 hover:text-indigo-500">
                        Visa alla yrken <span aria-hidden="true">&rarr;</span>
                    </a>
                </div>
            </div>
            {% endif %}

            <!-- Infographic Section -->
            <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 mt-24">
                <div class="bg-white rounded-2xl shadow-sm ring-1 ring-slate-900/5 p-8 sm:p-12">
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                        <div>
                            <h2 class="text-2xl font-bold text-slate-900 mb-4">Så fördelas din lön i Sverige</h2>
                            <p class="text-slate-600 mb-6">När du får din bruttolön går en del till skatt och arbetsgivaravgifter. Nedan ser du en typisk fördelning för en inkomst på 35 000 kr.</p>
                            <ul class="space-y-3 text-sm">
                                <li class="flex items-center gap-3"><span class="w-3 h-3 rounded-full bg-emerald-500"></span><span class="font-medium text-slate-900">Nettolön (kvar i plånboken): ~26 000 kr</span></li>
                                <li class="flex items-center gap-3"><span class="w-3 h-3 rounded-full bg-indigo-500"></span><span class="font-medium text-slate-900">Kommunal- & Statlig skatt: ~9 000 kr</span></li>
                                <li class="flex items-center gap-3"><span class="w-3 h-3 rounded-full bg-slate-300"></span><span class="font-medium text-slate-900">Arbetsgivaravgift (31.42%): ~11 000 kr</span></li>
                            </ul>
                        </div>
                        <div class="flex justify-center">
                            <!-- Inline SVG Infographic for SEO (acts as image with title) -->
                            <figure>
                                <svg viewBox="0 0 200 200" class="w-48 h-48 sm:w-64 sm:h-64" role="img" aria-label="Cirkeldiagram som visar fördelning av lön i Sverige: Nettolön, Skatt och Arbetsgivaravgift">
                                    <title>Fördelning av lön efter skatt i Sverige</title>
                                    <!-- Netto (56%) -->
                                    <circle cx="100" cy="100" r="90" fill="transparent" stroke="#10B981" stroke-width="20" stroke-dasharray="317 565" stroke-dashoffset="0"></circle>
                                    <!-- Skatt (25%) -->
                                    <circle cx="100" cy="100" r="90" fill="transparent" stroke="#6366F1" stroke-width="20" stroke-dasharray="141 565" stroke-dashoffset="-317"></circle>
                                    <!-- Arbetsgivaravgift (19%) -->
                                    <circle cx="100" cy="100" r="90" fill="transparent" stroke="#CBD5E1" stroke-width="20" stroke-dasharray="107 565" stroke-dashoffset="-458"></circle>
                                    <text x="100" y="95" text-anchor="middle" class="text-2xl font-bold fill-slate-900">~56%</text>
                                    <text x="100" y="115" text-anchor="middle" class="text-xs fill-slate-500">Nettolön</text>
                                </svg>
                                <figcaption class="sr-only">Diagram som visar att cirka 56% av bruttolönen blir nettolön i Sverige efter skatter och avgifter.</figcaption>
                            </figure>
                        </div>
                    </div>
                </div>
            </div>

            <!-- FAQ Section (Visible) -->
            <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 mt-24 mb-16">
                <h2 class="text-2xl font-bold text-slate-900 text-center mb-12">Vanliga frågor om lön och skatt</h2>
                <dl class="space-y-6 divide-y divide-slate-200">
                    <div class="pt-6">
                        <dt class="text-base font-semibold leading-7 text-slate-900">Hur räknar man ut lön efter skatt?</dt>
                        <dd class="mt-2 text-base leading-7 text-slate-600">
                            Nettolönen beräknas genom att dra av kommunalskatt och eventuell statlig inkomstskatt från bruttolönen. Jobbskatteavdraget sänker den totala skatten. Använd vår kalkylator ovan för exakt beräkning baserat på din kommun.
                        </dd>
                    </div>
                    <div class="pt-6">
                        <dt class="text-base font-semibold leading-7 text-slate-900">Vad är skillnaden mellan brutto och netto?</dt>
                        <dd class="mt-2 text-base leading-7 text-slate-600">
                            Bruttolön är lönen innan skatt, alltså det som står i ditt anställningsavtal. Nettolön är det belopp som faktiskt betalas ut till dig efter att skatten har dragits. <a href="/brutto-netto" class="text-indigo-600 hover:underline">Läs mer om skillnaden</a>.
                        </dd>
                    </div>
                    <div class="pt-6">
                        <dt class="text-base font-semibold leading-7 text-slate-900">Hur mycket skatt betalar man i Sverige 2026?</dt>
                        <dd class="mt-2 text-base leading-7 text-slate-600">
                            Skatten varierar beroende på kommun (ca 29-35%). Den genomsnittliga kommunalskatten i Sverige är cirka 32.37%. Personer med hög inkomst (över 615 300 kr/år) betalar även statlig inkomstskatt på 20%.
                        </dd>
                    </div>
                </dl>
            </div>

        </div>
        {% endblock %}
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-slate-200">
        <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
            <!-- Footer Grid - using lg:grid-cols-4 which exists in CSS -->
