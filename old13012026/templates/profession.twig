{% extends "home.twig" %}

{% block head_extra %}
<!-- Occupation Schema.org - Enriched with SCB Data -->
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "Occupation",
    "name": "{{ profession.title }}",
    "description": "{{ profession.description|e('js') }}",
    {% if profession.scb is defined and profession.scb.ssyk_code is defined %}
    "occupationalCategory": "{{ profession.scb.ssyk_code }}",
    {% endif %}
    "occupationLocation": {
        "@type": "Country",
        "name": "Sweden",
        "sameAs": "https://sv.wikipedia.org/wiki/Sverige"
    },
    "estimatedSalary": {
        "@type": "MonetaryAmountDistribution",
        "name": "Månadslön",
        "currency": "SEK",
        "duration": "P1M",
        {% if profession.scb is defined and profession.scb.salary_total > 0 %}
        "median": {{ profession.scb.salary_total }},
        "percentile10": {{ profession.scb.percentiles.p10 > 0 ? profession.scb.percentiles.p10 : (profession.median_salary * 0.7)|round }},
        "percentile25": {{ profession.scb.percentiles.p25 > 0 ? profession.scb.percentiles.p25 : (profession.median_salary * 0.85)|round }},
        "percentile75": {{ profession.scb.percentiles.p75 > 0 ? profession.scb.percentiles.p75 : (profession.avg_salary * 1.15)|round }},
        "percentile90": {{ profession.scb.percentiles.p90 > 0 ? profession.scb.percentiles.p90 : (profession.avg_salary * 1.35)|round }}
        {% else %}
        "median": {{ profession.median_salary }},
        "percentile25": {{ (profession.median_salary * 0.85)|round }},
        "percentile75": {{ (profession.avg_salary * 1.15)|round }}
        {% endif %}
    },
    "educationRequirements": "{{ profession.education|e('js') }}",
    "qualifications": "{{ profession.education|e('js') }}"
}
</script>

{% if profession.scb is defined and profession.scb.salary_men > 0 and profession.scb.salary_women > 0 %}
<!-- FAQPage Schema.org for SCB Data -->
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        {
            "@type": "Question",
            "name": "Vad är medellönen för en {{ profession.title|lower }} {{ profession.scb.year }}?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Enligt SCB:s officiella statistik är medellönen för en {{ profession.title|lower }} {{ profession.scb.salary_total|number_format(0, ' ', ' ') }} kr per månad ({{ profession.scb.year }})."
            }
        },
        {
            "@type": "Question",
            "name": "Tjänar män eller kvinnor mer som {{ profession.title|lower }}?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Män tjänar i genomsnitt {{ profession.scb.salary_men|number_format(0, ' ', ' ') }} kr medan kvinnor tjänar {{ profession.scb.salary_women|number_format(0, ' ', ' ') }} kr. Kvinnor tjänar {{ profession.scb.gender_gap_percent }}% av mäns lön."
            }
        }
        {% if profession.scb.evolution_10y_percent is defined %},
        {
            "@type": "Question",
            "name": "Hur har lönen för {{ profession.title|lower }} utvecklats?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Lönen för {{ profession.title|lower }} har ökat med {{ profession.scb.evolution_10y_percent }}% under de senaste 10 åren (2014-2024), enligt SCB."
            }
        }
        {% endif %}
    ]
}
</script>
{% endif %}

<!-- BreadcrumbList Schema.org -->
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {
            "@type": "ListItem",
            "position": 1,
            "name": "Hem",
            "item": "https://raknalon.se/"
        },
        {
            "@type": "ListItem",
            "position": 2,
            "name": "Yrken",
            "item": "https://raknalon.se/yrken"
        },
        {
            "@type": "ListItem",
            "position": 3,
            "name": "{{ profession.category|default('Allmänt') }}",
            "item": "https://raknalon.se/yrken#{{ profession.category|default('Allmänt')|lower|replace({' ': '-', '&': ''}) }}"
        },
        {
            "@type": "ListItem",
            "position": 4,
            "name": "{{ profession.title }}",
            "item": "https://raknalon.se/lon/{{ profession.slug }}"
        }
    ]
}
</script>
{% endblock %}

{% block content %}
<div class="bg-slate-50 pt-12 pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <!-- Breadcrumb -->
        <nav class="flex mb-8" aria-label="Breadcrumb">
            <ol role="list" class="flex items-center space-x-2">
                <li><a href="/" class="text-sm font-medium text-slate-500 hover:text-indigo-600">Hem</a></li>
                <li><span class="text-slate-300">/</span></li>
                <li><a href="/yrken" class="text-sm font-medium text-slate-500 hover:text-indigo-600">Yrken</a></li>
                <li><span class="text-slate-300">/</span></li>
                <li><span class="text-sm font-medium text-slate-500">{{ profession.category|default('Allmänt') }}</span></li>
                <li><span class="text-slate-300">/</span></li>
                <li><span class="text-sm font-medium text-indigo-600" aria-current="page">{{ profession.title }}</span></li>
            </ol>
        </nav>

        <!-- Header -->
        <div class="text-center mb-12">
            <div class="flex flex-col items-center justify-center gap-4 mb-8">
                <div class="flex items-center justify-center gap-2">
                    <span class="inline-flex items-center rounded-md bg-indigo-50 px-2.5 py-1 text-xs font-medium text-indigo-700 ring-1 ring-inset ring-indigo-700/10">
                        Lönestatistik 2026
                    </span>
                    {% if profession.category %}
                    <span class="inline-flex items-center rounded-md bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-600 ring-1 ring-inset ring-slate-500/10">
                        {{ profession.category }}
                    </span>
                    {% endif %}
                </div>
            </div>
            <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-5xl mb-4">
                Hur mycket tjänar en {{ profession.title }}?
            </h1>
            <p class="text-lg text-slate-600 max-w-2xl mx-auto">
                Se aktuell lönestatistik, utbildningskrav och räkna ut vad en {{ profession.title|lower }} får ut efter skatt.
            </p>
        </div>

        <!-- Stats Grid -->
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-3 mb-12">
            <!-- Snittlön (SCB or fallback) -->
            <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-slate-900/5 px-6 py-6">
                <dt class="truncate text-sm font-medium text-slate-500">Snittlön</dt>
                {% if profession.scb is defined and profession.scb.salary_total > 0 %}
                <dd class="mt-2 text-3xl font-bold tracking-tight text-slate-900">{{ profession.scb.salary_total|number_format(0, ',', ' ') }} kr</dd>
                <dd class="mt-2 text-sm text-slate-500">Privat sektor (SCB {{ profession.scb.year }})</dd>
                {% else %}
                <dd class="mt-2 text-3xl font-bold tracking-tight text-slate-900">{{ profession.avg_salary|number_format(0, ',', ' ') }} kr</dd>
                <dd class="mt-2 text-sm text-slate-500">Genomsnitt i Sverige</dd>
                {% endif %}
            </div>
            <!-- Median -->
            <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-slate-900/5 px-6 py-6">
                <dt class="truncate text-sm font-medium text-slate-500">Medianlön</dt>
                <dd class="mt-2 text-3xl font-bold tracking-tight text-slate-900">{{ profession.median_salary|number_format(0, ',', ' ') }} kr</dd>
                <dd class="mt-2 flex items-center text-sm text-emerald-600 font-medium">
                    <svg class="h-4 w-4 mr-1" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12 7a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0V8.414l-4.293 4.293a1 1 0 01-1.414 0L8 10.414l-4.293 4.293a1 1 0 01-1.414-1.414l5-5a1 1 0 011.414 0L8.586 10l-4.293 4.293z" clip-rule="evenodd"/></svg>
                    Vanligaste lönen
                </dd>
            </div>
            <!-- Löneutveckling or Efterfrågan -->
            <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-slate-900/5 px-6 py-6">
                {% if profession.scb is defined and profession.scb.evolution_10y_percent %}
                <dt class="truncate text-sm font-medium text-slate-500">Löneutveckling</dt>
                <dd class="mt-2 text-3xl font-bold tracking-tight text-emerald-600">+{{ profession.scb.evolution_10y_percent }}%</dd>
                <dd class="mt-2 text-sm text-slate-500">Senaste 10 åren</dd>
                {% else %}
                <dt class="truncate text-sm font-medium text-slate-500">Efterfrågan</dt>
                <dd class="mt-2 text-3xl font-bold tracking-tight text-slate-900">Hög</dd>
                <dd class="mt-2 text-sm text-slate-500">Framtidsutsikter: Goda</dd>
                {% endif %}
            </div>
        </div>

        <!-- Grid Layout: Main Content + Sticky TOC -->
        <div id="toc-grid" class="lg:grid lg:grid-cols-[1fr_240px] lg:gap-8">
        <div>

        {# ============================================== #}
        {# BLOC SCB 1: Source Officielle + Gender Gap    #}
        {# ============================================== #}
        {% if profession.scb is defined and profession.scb.salary_total > 0 %}
        <div class="mb-12">
            <!-- Source discrète -->
            <div class="flex items-center justify-end mb-2">
                <a href="https://www.scb.se/hitta-statistik/sverige-i-siffror/lonestatistik/" 
                   target="_blank" 
                   rel="noopener noreferrer"
                   class="text-xs text-slate-400 hover:text-indigo-600 transition-colors">
                    Källa: SCB {{ profession.scb.year }} →
                </a>
            </div>

            <!-- Gender Pay Gap Section -->
            {% if profession.scb.salary_men > 0 and profession.scb.salary_women > 0 %}
            <div class="bg-white rounded-2xl shadow-sm ring-1 ring-slate-900/5 p-6 sm:p-8">
                <h3 class="text-lg font-bold text-slate-900 mb-6 flex items-center gap-2">
                    <svg class="h-5 w-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                    </svg>
                    Löneskillnad mellan könen
                </h3>
                
                <div class="space-y-4">
                    <!-- Men Bar -->
                    <div class="flex items-center gap-4">
                        <span class="w-20 text-sm font-medium text-slate-600">Män</span>
                        <div class="flex-1 relative">
                            <div style="height: 32px; background: linear-gradient(90deg, #3b82f6, #2563eb); border-radius: 9999px; width: 100%; display: flex; align-items: center; justify-content: flex-end; padding-right: 12px;">
                                <span style="font-size: 12px; font-weight: 700; color: white;">{{ profession.scb.salary_men|number_format(0, ' ', ' ') }} kr</span>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Women Bar -->
                    <div class="flex items-center gap-4">
                        <span class="w-20 text-sm font-medium text-slate-600">Kvinnor</span>
                        <div class="flex-1 relative" style="background: #f1f5f9; border-radius: 9999px;">
                            <div style="height: 32px; background: linear-gradient(90deg, #ec4899, #db2777); border-radius: 9999px; width: {{ profession.scb.gender_gap_percent }}%; min-width: 120px; display: flex; align-items: center; justify-content: flex-end; padding-right: 12px;">
                                <span style="font-size: 12px; font-weight: 700; color: white;">{{ profession.scb.salary_women|number_format(0, ' ', ' ') }} kr</span>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="mt-6 p-4 bg-slate-50 rounded-xl">
                    {% if profession.scb.gender_gap_percent < 100 %}
                    <p class="text-sm text-slate-600">
                        Kvinnliga {{ profession.title|lower }} tjänar <strong class="text-pink-600">{{ profession.scb.gender_gap_percent }}%</strong> av mäns lön, 
                        vilket innebär en skillnad på <strong>{{ (profession.scb.salary_men - profession.scb.salary_women)|number_format(0, ' ', ' ') }} kr/mån</strong>.
                    </p>
                    {% elseif profession.scb.gender_gap_percent > 100 %}
                    <p class="text-sm text-slate-600">
                        <strong class="text-emerald-600">Intressant:</strong> Kvinnliga {{ profession.title|lower }} tjänar 
                        <strong class="text-emerald-600">{{ (profession.scb.gender_gap_percent - 100)|round }}%</strong> mer än sina manliga kollegor.
                    </p>
                    {% else %}
                    <p class="text-sm text-slate-600">
                        <strong class="text-emerald-600">Jämställt:</strong> Lönen för {{ profession.title|lower }} är lika för män och kvinnor.
                    </p>
                    {% endif %}
                </div>
            </div>
            {% endif %}
        </div>
        {% endif %}

        {# ============================================== #}
        {# BLOC SCB 2: Historique 10 ans                 #}
        {# ============================================== #}
        {% if profession.scb is defined and profession.scb.history|length > 0 and profession.scb.history['2024']|default(0) > 0 %}
        <div class="bg-white rounded-2xl shadow-sm ring-1 ring-slate-900/5 p-6 sm:p-8 mb-12">
            <h3 class="text-lg font-bold text-slate-900 mb-6 flex items-center gap-2">
                <svg class="h-5 w-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                </svg>
                Löneutveckling 2014–2024
            </h3>
            
            <div class="h-64">
                <canvas id="salaryHistoryChart"></canvas>
            </div>
            
            {% if profession.scb.evolution_10y_percent %}
            <div class="mt-6 p-4 bg-emerald-50 rounded-xl border border-emerald-100">
                <p class="text-sm text-emerald-800">
                    <strong>+{{ profession.scb.evolution_10y_percent }}%</strong> löneutveckling på 10 år
                    (från {{ profession.scb.history['2014']|number_format(0, ' ', ' ') }} kr till {{ profession.scb.salary_total|number_format(0, ' ', ' ') }} kr)
                </p>
            </div>
            {% endif %}
        </div>
        
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
        document.addEventListener('DOMContentLoaded', function() {
            const ctx = document.getElementById('salaryHistoryChart');
            if (ctx) {
                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: [{% for year, salary in profession.scb.history %}'{{ year }}'{% if not loop.last %}, {% endif %}{% endfor %}],
                        datasets: [{
                            label: 'Månadslön (kr)',
                            data: [{% for year, salary in profession.scb.history %}{{ salary }}{% if not loop.last %}, {% endif %}{% endfor %}],
                            borderColor: 'rgb(79, 70, 229)',
                            backgroundColor: 'rgba(79, 70, 229, 0.1)',
                            fill: true,
                            tension: 0.3,
                            pointBackgroundColor: 'rgb(79, 70, 229)',
                            pointBorderColor: '#fff',
                            pointBorderWidth: 2,
                            pointRadius: 4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        return context.parsed.y.toLocaleString('sv-SE') + ' kr';
                                    }
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: false,
                                ticks: {
                                    callback: function(value) {
                                        return value.toLocaleString('sv-SE') + ' kr';
                                    }
                                }
                            }
                        }
                    }
                });
            }
        });
        </script>
        {% endif %}

        <!-- Calculator Embed -->
        <div class="bg-indigo-900 rounded-2xl shadow-xl overflow-hidden mb-16" x-data="salaryCalculator()" x-init="salary = '{{ profession.median_salary }}'; age = 30;">
            <div class="px-6 py-12 sm:px-12 lg:py-16 text-center">
                <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl mb-6">Vad får en {{ profession.title|lower }} ut i lön?</h2>
                <p class="mx-auto mt-2 max-w-xl text-lg text-indigo-200 mb-10">
                    Använd vår kalkylator för att se nettolönen baserat på din kommun och ålder. Förinställd på medianlön.
                </p>

                <div class="bg-white rounded-xl shadow-lg p-6 max-w-lg mx-auto text-left">
                     <form @submit.prevent="calculate" class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-slate-700">Månadslön (Brutto)</label>
                            <div class="relative mt-1 rounded-md shadow-sm">
                                <input type="number" x-model="salary" class="block w-full rounded-md border-slate-300 pl-3 focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm py-2.5" placeholder="{{ profession.median_salary }}">
                                <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                                    <span class="text-slate-500 sm:text-sm">kr</span>
                                </div>
                            </div>
                        </div>
                        
                         <div>
                            <label class="block text-sm font-medium text-slate-700">Kommun</label>
                            <select x-model="selectedMunicipality" @change="updateTaxRate" class="mt-1 block w-full rounded-md border-slate-300 py-2.5 pl-3 pr-10 text-base focus:border-indigo-500 focus:outline-none focus:ring-indigo-500 sm:text-sm">
                                <option value="">Riket (Snitt 32.37%)</option>
                                {% for kommun in municipalities %}
                                    <option value="{{ kommun.tax_rate }}">{{ kommun.name }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <button type="submit" class="w-full bg-indigo-600 text-white rounded-lg py-3 px-4 hover:bg-indigo-700 font-bold shadow-sm transition-colors cursor-pointer">
                            Beräkna Nettolön
                        </button>
                     </form>

                     <!-- Quick Result -->
                     <div x-show="result" x-transition class="mt-6 pt-6 border-t border-slate-100 text-center">
                        <p class="text-xs font-bold text-slate-500 uppercase tracking-wide">Nettolön att utbetala</p>
                        <p class="text-4xl font-extrabold text-indigo-600 mt-2" x-text="formatMoney(result?.net_salary) + ' kr'"></p>
                     </div>
                </div>
            </div>
        </div>

        <div>
        <!-- Content & FAQ Combined -->
        <article id="om-yrket" class="prose prose-lg prose-indigo w-full max-w-none bg-white p-8 sm:p-12 rounded-2xl shadow-sm ring-1 ring-slate-900/5" style="position: relative;">
            {% if profession.banner_image %}
            <div style="position: absolute; top: -80px; right: 0; max-width: 150px; z-index: 999;">
                <img src="{{ profession.banner_image }}" alt="{{ profession.title }}" class="w-full h-auto">
            </div>
            {% endif %}
            
            <h2 class="mt-0">Om yrket {{ profession.title }}</h2>
            
            <p>{{ profession.description }}</p>
            
            {% if profession.description_extended %}
            <p>{{ profession.description_extended }}</p>
            {% endif %}

            <h3 id="utbildning">Utbildning och behörighet</h3>
            <p>{{ profession.education }}</p>

            {% if profession.specialties %}
            <h3 id="specialisering">Lön per specialisering</h3>
            <p>Lönen varierar beroende på vilken inriktning du väljer:</p>
            <ul>
                {% for spec in profession.specialties %}
                <li><strong>{{ spec.name }}:</strong> ~{{ spec.salary|number_format(0, ',', ' ') }} kr/mån</li>
                {% endfor %}
            </ul>
            {% endif %}

            {% if profession.salary_by_sector %}
            <h3 id="sektor">Lön per sektor</h3>
            <ul>
                {% if profession.salary_by_sector.region %}
                <li><strong>Region (offentlig):</strong> ~{{ profession.salary_by_sector.region|number_format(0, ',', ' ') }} kr/mån</li>
                {% endif %}
                {% if profession.salary_by_sector.offentlig %}
                <li><strong>Offentlig sektor:</strong> ~{{ profession.salary_by_sector.offentlig|number_format(0, ',', ' ') }} kr/mån</li>
                {% endif %}
                {% if has_kommunal_data %}
                <li><strong><a href="/lon/{{ profession.slug }}/kommunal" class="text-indigo-600 hover:underline">Kommunal sektor</a>:</strong> 
                    {% if profession.salary_by_sector.kommunal %}
                        ~{{ profession.salary_by_sector.kommunal|number_format(0, ',', ' ') }} kr/mån
                    {% else %}
                        Se statistik
                    {% endif %}
                </li>
                {% endif %}
                {% if profession.salary_by_sector.privat %}
                <li><strong>Privat sektor:</strong> ~{{ profession.salary_by_sector.privat|number_format(0, ',', ' ') }} kr/mån</li>
                {% endif %}
                {% if profession.salary_by_sector['egenföretagare'] %}
                <li><strong>Egenföretagare:</strong> ~{{ profession.salary_by_sector['egenföretagare']|number_format(0, ',', ' ') }} kr/mån (varierar stort)</li>
                {% endif %}
                {% if profession.salary_by_sector['eget_foretag'] %}
                <li><strong>Eget företag:</strong> ~{{ profession.salary_by_sector['eget_foretag']|number_format(0, ',', ' ') }} kr/mån</li>
                {% endif %}
                {% if profession.salary_by_sector.bemanning %}
                <li><strong>Bemanningsföretag:</strong> ~{{ profession.salary_by_sector.bemanning|number_format(0, ',', ' ') }} kr/mån</li>
                {% endif %}
                {% if profession.salary_by_sector.norge %}
                <li><strong>Norge:</strong> ~{{ profession.salary_by_sector.norge|number_format(0, ',', ' ') }} kr/mån</li>
                {% endif %}
            </ul>
            {% endif %}

            {% if profession.workplaces %}
            <h3 id="arbetsplats">Lön per arbetsplats</h3>
            <p>Lönen varierar beroende på var du arbetar:</p>
            <ul>
                {% for wp in profession.workplaces %}
                <li><strong>{{ wp.name }}:</strong> ~{{ wp.salary|number_format(0, ',', ' ') }} kr/mån</li>
                {% endfor %}
            </ul>
            {% endif %}

            {% if profession.employers %}
            <h3 id="arbetsgivare">Lön per arbetsgivare</h3>
            <p>Lönen varierar beroende på vilken arbetsgivare du arbetar för:</p>
            <ul>
                {% for emp in profession.employers %}
                <li><strong>{{ emp.name }}:</strong> ~{{ emp.salary|number_format(0, ',', ' ') }} kr/mån</li>
                {% endfor %}
            </ul>
            {% endif %}

            {% if profession.salary_by_type %}
            <h3 id="typ-av-trafik">Lön per typ av trafik</h3>
            <ul>
                {% if profession.salary_by_type['persontåg'] %}
                <li><strong>Persontåg:</strong> ~{{ profession.salary_by_type['persontåg']|number_format(0, ',', ' ') }} kr/mån</li>
                {% endif %}
                {% if profession.salary_by_type['godståg'] %}
                <li><strong>Godståg:</strong> ~{{ profession.salary_by_type['godståg']|number_format(0, ',', ' ') }} kr/mån</li>
                {% endif %}
                {% if profession.salary_by_type['pendeltåg'] %}
                <li><strong>Pendeltåg:</strong> ~{{ profession.salary_by_type['pendeltåg']|number_format(0, ',', ' ') }} kr/mån</li>
                {% endif %}
            </ul>
            {% endif %}

            <h3 id="lonestatistik">Lönestatistik och faktorer</h3>
            <p>
                Lönen för en {{ profession.title|lower }} kan variera stort. Faktorer som påverkar lönen inkluderar:
            </p>
            <ul>
                <li><strong>Erfarenhet:</strong> Lönen stiger oftast med antalet år i yrket.</li>
                <li><strong>Sektor:</strong> Privat sektor har ofta något högre löner än offentlig sektor.</li>
                <li><strong>Geografi:</strong> Lönerna är generellt högre i storstadsregionerna (Stockholm, Göteborg, Malmö).</li>
            </ul>

            {% if profession.faq %}
            <hr class="my-12 border-slate-200">
            
            <h2 id="faq" class="text-2xl font-bold text-slate-900 mb-6">Vanliga frågor om {{ profession.title|lower }} lön</h2>
            <div class="not-prose bg-slate-50 rounded-xl border border-slate-200 divide-y divide-slate-200">
                {% for item in profession.faq %}
                <div class="p-6">
                    <h4 class="text-lg font-bold text-slate-900 mb-2">{{ item.question }}</h4>
                    <p class="text-slate-600 leading-relaxed">{{ item.answer }}</p>
                </div>
                {% endfor %}

                {# ====== FAQs dynamiques SCB ====== #}
                {% if profession.scb is defined and profession.scb.salary_total > 0 %}
                <div class="p-6 bg-indigo-50/50">
                    <h4 class="text-lg font-bold text-slate-900 mb-2">Vad är medellönen för en {{ profession.title|lower }} {{ profession.scb.year }}?</h4>
                    <p class="text-slate-600 leading-relaxed">
                        Enligt SCB:s officiella statistik är medellönen för en {{ profession.title|lower }} 
                        <strong>{{ profession.scb.salary_total|number_format(0, ',', ' ') }} kr</strong> per månad i privat sektor ({{ profession.scb.year }}).
                    </p>
                </div>
                
                {% if profession.scb.salary_men > 0 and profession.scb.salary_women > 0 %}
                <div class="p-6 bg-indigo-50/50">
                    <h4 class="text-lg font-bold text-slate-900 mb-2">Tjänar män eller kvinnor mer som {{ profession.title|lower }}?</h4>
                    <p class="text-slate-600 leading-relaxed">
                        {% if profession.scb.gender_gap_percent < 100 %}
                        Män tjänar i genomsnitt <strong>{{ profession.scb.salary_men|number_format(0, ',', ' ') }} kr</strong> 
                        medan kvinnor tjänar <strong>{{ profession.scb.salary_women|number_format(0, ',', ' ') }} kr</strong>.
                        Kvinnor tjänar alltså {{ profession.scb.gender_gap_percent }}% av mäns lön, 
                        en skillnad på {{ (profession.scb.salary_men - profession.scb.salary_women)|number_format(0, ',', ' ') }} kr/mån.
                        {% else %}
                        I detta yrke tjänar kvinnor faktiskt mer än män: 
                        <strong>{{ profession.scb.salary_women|number_format(0, ',', ' ') }} kr</strong> mot 
                        <strong>{{ profession.scb.salary_men|number_format(0, ',', ' ') }} kr</strong>.
                        {% endif %}
                    </p>
                </div>
                {% endif %}
                
                {% if profession.scb.evolution_10y_percent is defined %}
                <div class="p-6 bg-indigo-50/50">
                    <h4 class="text-lg font-bold text-slate-900 mb-2">Hur har lönen för {{ profession.title|lower }} utvecklats?</h4>
                    <p class="text-slate-600 leading-relaxed">
                        Lönen för {{ profession.title|lower }} har ökat med <strong>{{ profession.scb.evolution_10y_percent }}%</strong> 
                        under de senaste 10 åren (2014-2024), enligt SCB. 
                        Det motsvarar en årlig ökning på cirka {{ (profession.scb.evolution_10y_percent / 10)|round(1) }}%.
                    </p>
                </div>
                {% endif %}
                {% endif %}
            </div>
            {% endif %}
        </article>

        {# Kommunal Sector CTA - Show if we have data (via SSYK, Name or Static) #}
        {% if has_kommunal_data %}
        <div class="mt-12 bg-indigo-50 rounded-2xl p-6 ring-1 ring-indigo-100">
            <div class="flex items-start gap-4">
                <div class="flex-shrink-0">
                    <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                    </svg>
                </div>
                <div class="flex-1">
                    <h3 class="text-lg font-bold text-slate-900 mb-1">{{ profession.title }} i kommunal sektor</h3>
                    <p class="text-slate-600 text-sm mb-3">
                        Se detaljerad lönestatistik för {{ profession.title|lower }} inom kommunal sektor, inklusive jämförelse med privat sektor och löneskillnader mellan könen.
                    </p>
                    <a href="/lon/{{ profession.slug }}/kommunal" class="inline-flex items-center text-sm font-medium text-indigo-600 hover:text-indigo-700">
                        Visa kommunal lönestatistik
                        <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
        {% endif %}

        <!-- Related Blog Posts -->
        {% if related_posts %}
        <div class="mt-16 border-t border-slate-200 pt-10">
            <h3 class="text-2xl font-bold text-slate-900 mb-6">Läs mer om {{ profession.title|lower }}</h3>
            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
                {% for post in related_posts %}
                <a href="/blogg/{{ post.slug }}" class="group flex flex-col overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-slate-900/5 hover:ring-indigo-600/20 hover:shadow-md transition-all">
                    {% if post.image %}
                    <div class="aspect-w-16 aspect-h-9 w-full bg-slate-100 overflow-hidden">
                        <img src="{{ post.image }}" alt="{{ post.title }}" class="h-48 w-full object-cover object-center group-hover:scale-105 transition-transform duration-300">
                    </div>
                    {% endif %}
                    <div class="flex flex-1 flex-col p-6">
                        <div class="flex items-center gap-x-2 text-xs">
                            <time datetime="{{ post.date }}" class="text-slate-500">{{ post.formatted_date }}</time>
                            <span class="relative z-10 rounded-full bg-indigo-50 px-2 py-0.5 font-medium text-indigo-600">{{ post.category }}</span>
                        </div>
                        <h3 class="mt-3 text-lg font-semibold leading-6 text-slate-900 group-hover:text-indigo-600">
                            {{ post.title }}
                        </h3>
                        <p class="mt-2 line-clamp-3 text-sm leading-6 text-slate-600">{{ post.excerpt }}</p>
                    </div>
                </a>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        <!-- Related Professions -->
        {% if related_professions %}
        <div class="mt-16 border-t border-slate-200 pt-10">
            <h3 class="text-2xl font-bold text-slate-900 mb-6">Liknande yrken</h3>
            <div class="grid grid-cols-2 gap-4 sm:grid-cols-3">
                {% for p in related_professions %}
                <a href="/lon/{{ p.slug }}" class="group block rounded-lg bg-white p-4 ring-1 ring-slate-900/5 hover:ring-indigo-600/20 hover:shadow-md transition-all">
                    <span class="block text-sm font-semibold text-slate-900 group-hover:text-indigo-600">{{ p.title }}</span>
                    <span class="mt-1 block text-xs text-slate-500">{{ p.median_salary|number_format(0, ',', ' ') }} kr</span>
                </a>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        </div><!-- end main content -->



        <style>
        @media (min-width: 1024px) {
            #toc-sidebar {
                display: block !important;
            }
            #toc-grid {
                display: grid !important;
                grid-template-columns: 1fr 240px;
                gap: 2rem;
            }
        }
        .toc-link:hover {
            color: rgb(79, 70, 229);
            border-left-color: rgb(79, 70, 229);
        }
        .toc-link.active {
            color: rgb(79, 70, 229) !important;
            border-left-color: rgb(79, 70, 229) !important;
            font-weight: 600;
        }
        
        /* Heading anchor links */
        article h2[id],
        article h3[id],
        article h4[id] {
            position: relative;
        }
        article h2[id]:before,
        article h3[id]:before,
        article h4[id]:before {
            content: "#";
            position: absolute;
            left: -1.5rem;
            color: rgb(79, 70, 229);
            opacity: 1;
            cursor: pointer;
        }
        
        /* List bullets color */
        article ul > li::marker {
            color: rgb(79, 70, 229) !important;
        }

        article h2[id] a.anchor-link,
        article h3[id] a.anchor-link,
        article h4[id] a.anchor-link {
            position: absolute;
            left: -1.5rem;
            color: rgb(79, 70, 229);
            text-decoration: none;
            opacity: 0;
            transition: opacity 0.2s ease;
        }
        article h2[id]:hover a.anchor-link,
        article h3[id]:hover a.anchor-link,
        article h4[id]:hover a.anchor-link {
            opacity: 1;
        }
        </style>

        </div><!-- end grid -->
                <!-- Sticky Table of Contents -->
        <aside id="toc-sidebar" style="display: none;">
            <nav class="sticky" id="toc-nav" style="position: sticky; top: 6rem;">
                <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-900/5 p-6" style="background: white; border-radius: 0.75rem; box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05); border: 1px solid rgba(15, 23, 42, 0.05); padding: 1.5rem;">
                    <h3 class="text-sm font-semibold text-slate-900 mb-4" style="font-size: 0.875rem; font-weight: 600; color: rgb(15, 23, 42); margin-bottom: 1rem;">Innehåll</h3>
                    <ul class="space-y-2 text-sm" style="font-size: 0.875rem;">
                        <li>
                            <a href="#om-yrket" class="toc-link block py-1 text-slate-600 hover:text-indigo-600 transition-colors border-l-2 border-transparent hover:border-indigo-600 pl-3 -ml-3" data-target="om-yrket" style="display: block; padding: 0.25rem 0; color: rgb(71, 85, 105); border-left: 2px solid transparent; padding-left: 0.75rem; margin-left: -0.75rem; transition: all 0.2s;">
                                Om yrket
                            </a>
                        </li>
                        <li>
                            <a href="#utbildning" class="toc-link block py-1 text-slate-600 hover:text-indigo-600 transition-colors border-l-2 border-transparent hover:border-indigo-600 pl-3 -ml-3" data-target="utbildning" style="display: block; padding: 0.25rem 0; color: rgb(71, 85, 105); border-left: 2px solid transparent; padding-left: 0.75rem; margin-left: -0.75rem; transition: all 0.2s;">
                                Utbildning
                            </a>
                        </li>
                        <li>
                            <a href="#lonestatistik" class="toc-link block py-1 text-slate-600 hover:text-indigo-600 transition-colors border-l-2 border-transparent hover:border-indigo-600 pl-3 -ml-3" data-target="lonestatistik" style="display: block; padding: 0.25rem 0; color: rgb(71, 85, 105); border-left: 2px solid transparent; padding-left: 0.75rem; margin-left: -0.75rem; transition: all 0.2s;">
                                Lönestatistik
                            </a>
