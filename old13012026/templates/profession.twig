                        {% if profession.faq %}
                        <li>
                            <a href="#faq" class="toc-link block py-1 text-slate-600 hover:text-indigo-600 transition-colors border-l-2 border-transparent hover:border-indigo-600 pl-3 -ml-3" data-target="faq" style="display: block; padding: 0.25rem 0; color: rgb(71, 85, 105); border-left: 2px solid transparent; padding-left: 0.75rem; margin-left: -0.75rem; transition: all 0.2s;">
                                Vanliga frågor
                            </a>
                        </li>
                        {% endif %}
                    </ul>
                </div>
            </nav>
        </aside>
    </div>
    
</div>

<script>
// Smooth scroll and active section tracking for TOC
document.addEventListener('DOMContentLoaded', function() {
    const tocLinks = document.querySelectorAll('.toc-link');
    const sections = document.querySelectorAll('[id]');
    
    // Smooth scroll
    tocLinks.forEach(link => {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            const targetId = this.getAttribute('data-target');
            const targetSection = document.getElementById(targetId);
            if (targetSection) {
                targetSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
                // Manually set active class on click to avoid lag
                tocLinks.forEach(l => l.classList.remove('active'));
                this.classList.add('active');
            }
        });
    });
    
    // Track active section with IntersectionObserver
    const observerOptions = {
        root: null,
        rootMargin: '-10% 0px -70% 0px', // Adjusted to trigger earlier/better
        threshold: 0
    };
    
    const observerCallback = (entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const activeId = entry.target.id;
                tocLinks.forEach(link => {
                    link.classList.remove('active');
                    if (link.getAttribute('data-target') === activeId) {
                        link.classList.add('active');
                    }
                });
            }
        });
    };
    
    const observer = new IntersectionObserver(observerCallback, observerOptions);
    
    // Add all tracked section IDs here
    const trackedSections = [
        'om-yrket', 
        'utbildning', 
        'specialisering', 
        'sektor', 
        'arbetsplats', 
        'arbetsgivare', 
        'typ-av-trafik', 
        'lonestatistik', 
        'faq'
    ];
    
    trackedSections.forEach(id => {
        const section = document.getElementById(id);
        if (section) {
            observer.observe(section);
        }
    });
});
</script>
{% endblock %}
