														<td class="py-3 px-3 text-center text-slate-700" x-text="item.taxRate + '%'"></td>
													</template>
												</tr>
												<tr class="bg-gradient-to-r from-emerald-50/50 to-indigo-50/50">
													<td class="py-3 px-4 text-slate-700 font-semibold">vs. Första</td>
													<template x-for="(item, idx) in history" :key="'diff-' + item.id">
														<td class="py-3 px-3 text-center">
															<template x-if="idx === 0">
																<span class="text-slate-400">—</span>
															</template>
															<template x-if="idx !== 0">
																<div class="flex flex-col items-center">
																	<span class="font-bold" :class="getDifference(idx) > 0 ? 'text-emerald-600' : getDifference(idx) < 0 ? 'text-red-500' : 'text-slate-500'" x-text="(getDifference(idx) > 0 ? '+' : '') + formatMoney(getDifference(idx)) + '/mån'"></span>
																	<span class="text-xs mt-0.5" :class="getDifference(idx) > 0 ? 'text-emerald-500' : getDifference(idx) < 0 ? 'text-red-400' : 'text-slate-400'" x-text="(getDifference(idx) > 0 ? '+' : '') + formatMoney(getDifference(idx) * 12) + '/år'"></span>
																</div>
															</template>
														</td>
													</template>
												</tr>
											</tbody>
										</table>
									</div>
