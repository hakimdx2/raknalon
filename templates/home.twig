<!DOCTYPE html>
{% include 'partials/ads/config.twig' %}
<html lang="sv" class="h-full bg-slate-50 antialiased">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		{% set months_sv = {'01': 'Januari', '02': 'Februari', '03': 'Mars', '04': 'April', '05': 'Maj', '06': 'Juni', '07': 'Juli', '08': 'Augusti', '09': 'September', '10': 'Oktober', '11': 'November', '12': 'December'} %}
		{% set current_month_sv = months_sv["now"|date("m")] %}
		<title>{{ title|default('Lön efter skatt 2026 (' ~ current_month_sv ~ ') - Räkna ut din lön') }}</title>
		<meta name="description" content="{{ description|default('Lönekalkylator 2026 - Räkna ut din lön efter skatt gratis. Se exakt nettolön, skatter och arbetsgivaravgifter baserat på din kommun. Uppdaterad för inkomståret 2026.') }}">
		<link
		rel="canonical" href="https://raknalon.se{{ current_path|default('') }}">

		<!-- Open Graph -->
		<meta property="og:title" content="{{ title }}">
		<meta property="og:description" content="{{ description|default('Räkna ut din lön efter skatt med Sveriges enklaste lönekalkylator.') }}">
		<meta property="og:type" content="website">
		<meta property="og:url" content="https://raknalon.se{{ current_path|default('') }}">
		<meta
		property="og:image" content="https://raknalon.se/img/og-image.jpg">

		<!-- Favicon -->
		<link
		rel="icon" type="image/png" href="/img/favicon.png">


		<!-- Google AdSense -->
		<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1826806205536778" crossorigin="anonymous"></script>


		<!-- Hotjar Tracking Code for https://raknalon.se -->
		<script>
			(function (h, o, t, j, a, r) {
h.hj = h.hj || function () {
(h.hj.q = h.hj.q || []).push(arguments)
};
h._hjSettings = {
hjid: 6625397,
hjsv: 6
};
a = o.getElementsByTagName('head')[0];
r = o.createElement('script');
r.async = 1;
r.src = t + h._hjSettings.hjid + j + h._hjSettings.hjsv;
a.appendChild(r);
})(window, document, 'https://static.hotjar.com/c/hotjar-', '.js?sv=');
		</script>

		<!-- Schema.org Structured Data -->
		<script type="application/ld+json">
			{
																																																																																	        "@context": "https://schema.org",
																																																																																	        "@type": "WebApplication",
																																																																																	        "name": "Raknalon.se Lönekalkylator",
																																																																																	        "url": "https://raknalon.se",
																																																																																	        "description": "Räkna ut din lön efter skatt med Sveriges enklaste lönekalkylator. Se nettolön, skatter och arbetsgivaravgifter för inkomståret 2026.",
																																																																																	        "applicationCategory": "FinanceApplication",
																																																																																	        "operatingSystem": "All",
																																																																																	        "offers": {
																																																																																	            "@type": "Offer",
																																																																																	            "price": "0",
																																																																																	            "priceCurrency": "SEK"
																																																																																	        },
																																																																																	        "aggregateRating": {
																																																																																	            "@type": "AggregateRating",
																																																																																	            "ratingValue": "4.8",
																																																																																	            "reviewCount": "127"
																																																																																	        }
																																																																																	    }
		</script>
		{% if current_path is not defined or current_path == '' or current_path == '/' %}
			<script type="application/ld+json">
				{
																																																																																																												        "@context": "https://schema.org",
																																																																																																												        "@type": "FAQPage",
																																																																																																												        "mainEntity": [
																																																																																																												            {
																																																																																																												                "@type": "Question",
																																																																																																												                "name": "Hur räknar man ut lön efter skatt?",
																																																																																																												                "acceptedAnswer": {
																																																																																																												                    "@type": "Answer",
																																																																																																												                    "text": "Nettolönen beräknas genom att dra av kommunalskatt och eventuell statlig inkomstskatt från bruttolönen. Jobbskatteavdraget sänker den totala skatten. Använd vår kalkylator för exakt beräkning baserat på din kommun."
																																																																																																												                }
																																																																																																												            },
																																																																																																												            {
																																																																																																												                "@type": "Question",
																																																																																																												                "name": "Vad är skillnaden mellan brutto och netto?",
																																																																																																												                "acceptedAnswer": {
																																																																																																												                    "@type": "Answer",
																																																																																																												                    "text": "Bruttolön är lönen innan skatt, alltså det som står i ditt anställningsavtal. Nettolön är det belopp som faktiskt betalas ut till dig efter att skatten har dragits."
																																																																																																												                }
																																																																																																												            },
																																																																																																												            {
																																																																																																												                "@type": "Question",
																																																																																																												                "name": "Hur mycket skatt betalar man i Sverige 2026?",
																																																																																																												                "acceptedAnswer": {
																																																																																																												                    "@type": "Answer",
																																																																																																												                    "text": "Skatten varierar beroende på kommun (ca 29-35%). Den genomsnittliga kommunalskatten i Sverige är cirka 32.37%. Personer med hög inkomst (över 615 300 kr/år) betalar även statlig inkomstskatt på 20%."
																																																																																																												                }
																																																																																																												            }
																																																																																																												        ]
																																																																																																												    }
			</script>
		{% endif %}

		<!-- Google Fonts: Inter -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link
		href="https://fonts.googleapis.com/css2?family=Inter:wght@300..900&display=swap" rel="stylesheet">

		<!-- Tailwind CSS -->
		<link href="/css/app.css?v=2" rel="stylesheet">
		<link
		href="/css/newsletter.css" rel="stylesheet">

		<!-- Scripts -->
		<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
		<script src="/js/calculator.js?v=3"></script>

		<!-- Professions data for similar professions widget -->
		{% if all_professions %}
			<script type="application/json" id="professions-data">
				{{ all_professions|json_encode|raw }}
			</script>
		{% endif %}

		{% block head_extra %}{% endblock %}
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-B15NQWTYEP"></script>
		<script>
			window.dataLayer = window.dataLayer || [];
function gtag() {
dataLayer.push(arguments);
}
gtag('js', new Date());

gtag('config', 'G-B15NQWTYEP');
		</script>

		<!-- Grow.me -->
		<script data-grow-initializer="">
			!(function () {
window.growMe || ((window.growMe = function (e) {
window.growMe._.push(e);
}), (window.growMe._ =[]));
var e = document.createElement("script");
(e.type = "text/javascript"),
(e.src = "https://faves.grow.me/main.js"),
(e.defer =! 0),
e.setAttribute("data-grow-faves-site-id", "U2l0ZTo4OGNhMzk4Ni1lMzI2LTQzZDQtOTZhNS1lYzBjMTBlYjBkZDQ=");
var t = document.getElementsByTagName("script")[0];
t.parentNode.insertBefore(e, t);
})();
		</script>
	</head>
	<body
		class="h-full flex flex-col">

		<!-- Navigation -->
		<header class="bg-white/80 backdrop-blur-md sticky top-0 z-50 border-b border-slate-200" x-data="{ mobileMenuOpen: false }">
			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
				<div class="flex h-16 justify-between items-center">
					<div class="flex items-center gap-2">
						<a href="/" class="flex items-center gap-3 group">
							<img src="/img/logo-new.svg" alt="Räkna Lön Logo" class="h-10 w-10 rounded-lg shadow-sm transition-transform group-hover:scale-105">
							<span class="text-xl font-bold text-slate-900 tracking-tight">raknalon.se</span>
						</a>
					</div>

					<!-- Desktop Navigation -->
					<nav class="hidden md:flex gap-6 text-sm font-medium text-slate-600 items-center">
						<a href="/yrken" class="hover:text-indigo-600 transition-colors">Alla yrken</a>
						<a href="/kommunal-lon" class="hover:text-indigo-600 transition-colors">Kommunal lön</a>

						<a href="/blogg" class="hover:text-indigo-600 transition-colors">Blogg</a>
						<a href="/brutto-netto" class="hover:text-indigo-600 transition-colors">Brutto vs Netto</a>
						<a href="/jobbskatteavdrag" class="hover:text-indigo-600 transition-colors">Jobbskatteavdrag</a>
						<a href="/verktyg/lone-speedrunner" class="text-indigo-600 font-semibold hover:text-indigo-500 transition-colors flex items-center gap-1">
							<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
							Speedrunner
						</a>

						<a href="/" class="ml-4 inline-flex items-center justify-center rounded-lg bg-indigo-600 px-4 py-2 text-sm font-bold text-white shadow-sm hover:bg-indigo-500 transition-colors">
							Räkna ut lön
						</a>
					</nav>

					<!-- Mobile Hamburger Button -->
					<button type="button" @click="mobileMenuOpen = !mobileMenuOpen" class="md:hidden p-2 rounded-md text-slate-600 hover:bg-slate-100 hover:text-slate-900 transition-colors" aria-label="Toggle menu">
						<svg x-show="!mobileMenuOpen" class="h-6 w-6" fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
						</svg>
						<svg x-show="mobileMenuOpen" x-cloak class="h-6 w-6" fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
						</svg>
					</button>
				</div>
			</div>

			<!-- Mobile Menu Panel -->
			<div x-show="mobileMenuOpen" x-cloak x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 -translate-y-1" x-transition:enter-end="opacity-100 translate-y-0" x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100 translate-y-0" x-transition:leave-end="opacity-0 -translate-y-1" class="md:hidden border-t border-slate-200 bg-white">
				<div class="px-4 py-4 space-y-2">
					<a href="/yrken" class="block px-3 py-2 rounded-lg text-base font-medium text-slate-700 hover:bg-indigo-50 hover:text-indigo-600 transition-colors">Alla yrken</a>
					<a href="/kommunal-lon" class="block px-3 py-2 rounded-lg text-base font-medium text-slate-700 hover:bg-indigo-50 hover:text-indigo-600 transition-colors">Kommunal lön</a>

					<a href="/blogg" class="block px-3 py-2 rounded-lg text-base font-medium text-slate-700 hover:bg-indigo-50 hover:text-indigo-600 transition-colors">Blogg</a>
					<a href="/brutto-netto" class="block px-3 py-2 rounded-lg text-base font-medium text-slate-700 hover:bg-indigo-50 hover:text-indigo-600 transition-colors">Brutto vs Netto</a>
					<a href="/jobbskatteavdrag" class="block px-3 py-2 rounded-lg text-base font-medium text-slate-700 hover:bg-indigo-50 hover:text-indigo-600 transition-colors">Jobbskatteavdrag</a>
					<a href="/verktyg/lone-speedrunner" class="block px-3 py-2 rounded-lg text-base font-medium text-slate-700 hover:bg-indigo-50 hover:text-indigo-600 transition-colors flex items-center gap-2">
						Speedrunner
						<span class="bg-indigo-100 text-indigo-700 text-xs px-2 py-0.5 rounded-full font-bold">Ny</span>
					</a>
					<a href="/statlig-skatt" class="block px-3 py-2 rounded-lg text-base font-medium text-slate-700 hover:bg-indigo-50 hover:text-indigo-600 transition-colors">Statlig skatt</a>
				</div>
			</div>
		</header>


		<!-- Main Content -->
		<main
			class="flex-grow">
			<!-- Ezoic 101: top_of_page -->
			<div id="ezoic-pub-ad-placeholder-101"></div>
			{% block content %}
				<div
					class="relative isolate pt-14 pb-20 sm:pt-20 sm:pb-24">

					<!-- Background effects -->
					<div class="absolute inset-x-0 -top-40 -z-10 transform-gpu overflow-hidden blur-3xl sm:-top-80" aria-hidden="true">
						<div class="relative left-[calc(50%-11rem)] aspect-[1155/678] w-[36.125rem] -translate-x-1/2 rotate-[30deg] bg-gradient-to-tr from-[#ff80b5] to-[#9089fc] opacity-20 sm:left-[calc(50%-30rem)] sm:w-[72.1875rem]" style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)"></div>
					</div>

					<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
						<div class="mx-auto max-w-2xl text-center mb-12">
							<div class="mb-6 flex justify-center">
								<span class="relative rounded-full px-3 py-1 text-sm leading-6 text-indigo-600 ring-1 ring-inset ring-indigo-600/10 bg-indigo-50 font-medium">
									Uppdaterad för inkomståret 2026
								</span>
							</div>
							<h1 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-6xl mb-6">
								<span class="text-indigo-600">Lönekalkylator 2026</span>
								- Räkna ut lön efter skatt
							</h1>
							<p class="text-lg leading-8 text-slate-600">
								Sveriges mest använda lönekalkylator. Se exakt vad du får ut i handen baserat på din kommun och ålder. Gratis och uppdaterad med 2026 års skatteregler.
							</p>
						</div>

						<!-- Popular Professions (Internal Linking) -->
						<div class="mx-auto max-w-2xl text-center mb-10">
							<p class="text-sm text-slate-500 mb-2">Populära sökningar:</p>
							<div class="flex flex-wrap justify-center gap-3">
								<a href="/lon/sjukskoterska" class="text-sm font-medium text-indigo-600 hover:text-indigo-500 bg-indigo-50 px-3 py-1 rounded-full transition-colors">
									Lön Sjuksköterska 2026
								</a>
								<a href="/lon/underskoterska" class="text-sm font-medium text-indigo-600 hover:text-indigo-500 bg-indigo-50 px-3 py-1 rounded-full transition-colors">
									Lön Undersköterska 2026
								</a>
								<a href="/lon/polis" class="text-sm font-medium text-indigo-600 hover:text-indigo-500 bg-indigo-50 px-3 py-1 rounded-full transition-colors">
									Lön Polis 2026
								</a>
							</div>
						</div>

						<!-- Calculator Card -->
						<div class="mx-auto max-w-xl bg-white rounded-2xl shadow-xl shadow-indigo-900/5 ring-1 ring-slate-900/5 overflow-hidden" x-data="salaryCalculator()">
							<div class="p-6 sm:p-8">
								<form @submit.prevent="calculate" class="space-y-6">
									<div>
										<label for="salary" class="block text-sm font-semibold leading-6 text-slate-900">Månadslön (Brutto)</label>
										<div class="relative mt-2 rounded-lg shadow-sm">
											<div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
												<span class="text-slate-500 sm:text-sm font-medium">kr</span>
											</div>
											<input type="number" id="salary" x-model="salary" class="block w-full rounded-lg border-0 py-3.5 pl-10 text-slate-900 ring-1 ring-inset ring-slate-200 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-lg sm:leading-6 font-semibold transition-shadow" placeholder="T.ex. 35 000">
										</div>
									</div>

									<div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
										<div>
											<label for="municipality" class="block text-sm font-semibold leading-6 text-slate-900">Kommun</label>
											<div class="mt-2">
												<select id="municipality" x-model="selectedMunicipality" @change="updateTaxRate" class="block w-full rounded-lg border-0 py-3 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-200 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6">
													<option value="">Välj kommun...</option>
													{% for kommun in municipalities %}
														<option value="{{ kommun.tax_rate }}">{{ kommun.name }}</option>
													{% endfor %}
												</select>
											</div>
											<div class="flex justify-between mt-1.5 px-1">
												<p class="text-xs text-slate-500">Påverkar skattesatsen</p>
												<p class="text-xs font-medium text-indigo-600" x-show="selectedMunicipality" x-text="taxRate + '%'"></p>
											</div>
										</div>

										<div>
											<label for="age" class="block text-sm font-semibold leading-6 text-slate-900">Ålder</label>
											<div class="mt-2">
												<input type="number" id="age" x-model="age" class="block w-full rounded-lg border-0 py-3 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-200 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6" placeholder="30">
											</div>
											<p class="mt-1.5 px-1 text-xs text-slate-500">Påverkar jobbskatteavdraget</p>
										</div>
									</div>

									<button type="submit" :disabled="loading" :class="{'opacity-80 cursor-wait': loading, 'hover:bg-indigo-500': !loading}" class="w-full rounded-lg bg-indigo-600 px-4 py-4 text-sm font-bold text-white shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-all flex justify-center items-center gap-2">
										<span x-show="!loading">Beräkna lön</span>
										<span x-show="loading">Räknar...</span>
										<svg x-show="!loading" class="w-4 h-4 text-indigo-200" fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
									</button>
								</form>

								<!-- Results -->
								<div x-show="result" x-transition.opacity.duration.300ms class="mt-8 pt-8 border-t border-slate-100">
									<div class="text-center bg-indigo-50/50 rounded-xl p-6 border border-indigo-100">
										<p class="text-xs font-bold text-indigo-600 uppercase tracking-widest mb-1">Nettolön</p>
										<p class="text-4xl sm:text-5xl font-extrabold text-slate-900 tracking-tight" x-text="formatMoney(result?.net_salary)"></p>
										<p class="text-sm text-slate-500 mt-2 font-medium mb-6">Kronor kvar efter skatt</p>

										<!-- AdSense: Calculator Result (Aggressive Placement) -->
										{% include 'partials/ads/display.twig' with {'slot_name': 'home_calculator_result'} %}
									</div>

									<div class="mt-6 space-y-3">
										<div class="flex justify-between items-center p-3 rounded-lg hover:bg-slate-50 transition-colors">
											<span class="text-sm font-medium text-slate-600">Total skatt</span>
											<span class="text-sm font-bold text-slate-900" x-text="formatMoney(result?.total_tax) + ' kr'"></span>
										</div>
										<div class="flex justify-between items-center p-3 rounded-lg hover:bg-slate-50 transition-colors">
											<span class="text-sm font-medium text-slate-600">Arbetsgivaravgift</span>
											<span class="text-sm font-bold text-slate-900" x-text="formatMoney(result?.employer_cost) + ' kr'"></span>
										</div>
									</div>
								</div>

								<!-- Clickbait retention banner (alert style) -->
								<a href="/blogg/hemliga-loneforhandlings-tekniker" class="block mt-6 p-4 rounded-lg bg-amber-50 hover:bg-amber-100 transition-all duration-200 group animate-attention hover:animate-none">
									<div class="flex items-center gap-3">
										<div class="flex-shrink-0">
											<svg class="w-6 h-6 text-amber-600" fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="2">
												<path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
											</svg>
										</div>
										<div class="flex-1 min-w-0">
											<p class="text-sm font-bold text-amber-800">
												Vill du tjäna 50% mer? Det här vill din chef INTE att du vet...
											</p>
											<p class="text-xs text-amber-700 mt-0.5">
												Avslöjar de hemliga förhandlingsteknikerna som fungerar 2026
											</p>
										</div>
										<svg class="w-5 h-5 text-amber-500 group-hover:text-amber-700 group-hover:translate-x-1 transition-all flex-shrink-0" fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="2">
											<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
										</svg>
									</div>
								</a>

								<!-- Similar Professions Widget -->
								<div x-show="result && similarProfessions.length > 0" x-transition:enter="transition ease-out duration-500 delay-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0" class="mt-6 pt-6 border-t border-slate-100">

									<div class="flex items-center gap-2 mb-4">
										<svg class="w-4 h-4 text-emerald-500" fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="2">
