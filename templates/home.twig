													<svg class="w-3.5 h-3.5" fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
														<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
													</svg>
												</button>
											</div>
										</template>
									</div>

									<!-- Compare Button -->
									<button x-show="history.length >= 2" @click="showCompare = !showCompare" class="w-full flex items-center justify-center gap-2 py-2.5 px-4 rounded-lg text-sm font-semibold transition-all duration-200" :class="showCompare ? 'bg-indigo-100 text-indigo-700' : 'bg-slate-50 text-slate-600 hover:bg-slate-100'">
										<svg class="w-4 h-4" fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="2">
											<path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
										</svg>
										<span x-text="showCompare ? 'Dölj jämförelse' : 'Jämför alla'"></span>
									</button>

									<!-- Compare Table -->
									<div x-show="showCompare && history.length >= 2" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 scale-95" x-transition:enter-end="opacity-100 scale-100" class="mt-4 overflow-x-auto rounded-xl border border-slate-200 bg-gradient-to-br from-slate-50 to-white">
										<table class="w-full text-sm">
											<thead>
												<tr class="border-b border-slate-200">
