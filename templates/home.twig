														<td class="py-3 px-3 text-center text-slate-700" x-text="formatMoney(item.tax) + ' kr'"></td>
													</template>
												</tr>
												<tr>
													<td class="py-3 px-4 text-slate-600 font-medium">Skattesats</td>
