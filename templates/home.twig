													<template x-for="(item, idx) in history" :key="'th-' + item.id">
														<th class="py-3 px-3 text-center min-w-[100px]">
															<div class="flex flex-col items-center gap-1">
																<span class="font-bold text-slate-900" x-text="formatMoney(item.gross) + ' kr'"></span>
																<span class="text-xs text-slate-400 truncate max-w-[90px]" x-text="item.municipalityName"></span>
															</div>
														</th>
													</template>
												</tr>
											</thead>
											<tbody class="divide-y divide-slate-100">
												<tr>
													<td class="py-3 px-4 text-slate-600 font-medium">Nettolön</td>
													<template x-for="(item, idx) in history" :key="'net-' + item.id">
														<td class="py-3 px-3 text-center">
															<span class="font-bold" :class="idx === 0 ? 'text-indigo-600' : 'text-slate-900'" x-text="formatMoney(item.net) + ' kr'"></span>
														</td>
													</template>
												</tr>
												<tr>
													<td class="py-3 px-4 text-slate-600 font-medium">Skatt</td>
