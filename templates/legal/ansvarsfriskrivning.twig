{% extends "home.twig" %}

{% block head_extra %}
<meta name="robots" content="index, follow">
{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto px-4 py-12 sm:py-16">
    <article class="prose prose-slate prose-lg max-w-none">
        
        <!-- Header -->
        <div class="not-prose mb-10">
            <nav class="flex mb-4" aria-label="Breadcrumb">
                <ol class="flex items-center space-x-2 text-sm text-slate-500">
                    <li><a href="/" class="hover:text-indigo-600">Hem</a></li>
                    <li><span class="mx-2">/</span></li>
                    <li class="text-slate-900 font-medium">Ansvarsfriskrivning</li>
                </ol>
            </nav>
            <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-2">Ansvarsfriskrivning</h1>
            <p class="text-sm text-slate-500">Gäller från: Januari 2026</p>
        </div>

        <!-- Important Notice -->
        <div class="not-prose bg-amber-50 border border-amber-200 rounded-xl p-6 mb-10">
            <h2 class="text-lg font-semibold text-amber-800 mb-2">Viktigt att läsa</h2>
            <p class="text-amber-700">Alla beräkningar på raknalon.se är <strong>uppskattningar</strong> och ska inte betraktas som finansiell eller juridisk rådgivning. Din faktiska lön kan skilja sig från våra beräkningar.</p>
        </div>

        <!-- General -->
        <section class="mb-10">
            <h2 class="text-xl font-semibold text-slate-800">1. Allmänt</h2>
            <p>Raknalon.se tillhandahåller onlineverktyg för att beräkna lön efter skatt, jämföra löner mellan yrken och förstå det svenska skattesystemet.</p>
            <p>All information och alla beräkningar som presenteras på denna webbplats är avsedda endast för informationsändamål och utgör <strong>inte</strong> professionell finansiell, skattemässig eller juridisk rådgivning.</p>
        </section>

        <!-- Estimates -->
        <section class="mb-10">
            <h2 class="text-xl font-semibold text-slate-800">2. Uppskattningar, inte garantier</h2>
            <p>Våra lönekalkylatorer ger <strong>uppskattningar</strong> baserade på:</p>
            <ul class="list-disc pl-6 space-y-1 text-slate-600">
                <li>Officiella skattesatser publicerade av Skatteverket</li>
                <li>Kommunala skattesatser från Sveriges Kommuner och Regioner (SKR)</li>
                <li>Jobbskatteavdragsregler för aktuellt inkomstår</li>
                <li>Lönestatistik från SCB (Statistiska Centralbyrån)</li>
            </ul>
            
            <p class="mt-4">Din faktiska nettolön kan <strong>avvika</strong> från våra beräkningar på grund av:</p>
            <ul class="list-disc pl-6 space-y-1 text-slate-600">
                <li>Personliga skatteavdrag (ränteavdrag, ROT/RUT, etc.)</li>
                <li>Förmåner (tjänstebil, lunch, friskvård)</li>
                <li>Särskilda skatteregler (t.ex. expertskatt för utländska experter)</li>
                <li>Fackliga avgifter och andra löneavdrag</li>
                <li>Individuella beslut från Skatteverket</li>
                <li>Tjänstepension och andra avsättningar</li>
            </ul>
        </section>

        <!-- Salary Statistics -->
        <section class="mb-10">
            <h2 class="text-xl font-semibold text-slate-800">3. Lönestatistik</h2>
            <p>Löneuppgifterna för olika yrken på raknalon.se baseras på officiell statistik och kollektivavtal, men representerar <strong>genomsnitt och medianer</strong>.</p>
            <p>Din faktiska lön påverkas av:</p>
            <ul class="list-disc pl-6 space-y-1 text-slate-600">
                <li>Erfarenhet och utbildningsnivå</li>
                <li>Arbetsgivare och bransch</li>
                <li>Geografisk plats i Sverige</li>
                <li>Förhandlingsförmåga</li>
                <li>Konjunktur och arbetsmarknad</li>
                <li>Specialiseringar och certifieringar</li>
            </ul>
        </section>

        <!-- Not Financial Advice -->
        <section class="mb-10">
            <h2 class="text-xl font-semibold text-slate-800">4. Ingen finansiell rådgivning</h2>
            <p>Informationen på raknalon.se ska <strong>inte</strong> betraktas som:</p>
            <ul class="list-disc pl-6 space-y-1 text-slate-600">
                <li>Finansiell rådgivning</li>
                <li>Skatterådgivning</li>
                <li>Juridisk rådgivning</li>
                <li>Investeringsrådgivning</li>
                <li>Arbetsrättslig rådgivning</li>
            </ul>
            
            <div class="bg-indigo-50 border-l-4 border-indigo-500 p-5 rounded-r-lg mt-6 not-prose">
                <p class="text-indigo-800">
                    <strong>Rekommendation:</strong> För beslut som rör din ekonomi, konsultera alltid en kvalificerad expert som en auktoriserad revisor, skattejurist eller kontakta Skatteverket direkt.
                </p>
            </div>
        </section>

        <!-- Limitation of Liability -->
        <section class="mb-10">
            <h2 class="text-xl font-semibold text-slate-800">5. Ansvarsbegränsning</h2>
            <p>Raknalon.se och dess ägare:</p>
            <ul class="list-disc pl-6 space-y-1 text-slate-600">
                <li>Garanterar inte att informationen är korrekt, fullständig eller aktuell</li>
                <li>Ansvarar inte för eventuella fel i beräkningar eller statistik</li>
                <li>Ansvarar inte för ekonomiska beslut baserade på webbplatsens innehåll</li>
                <li>Ansvarar inte för skador som kan uppstå till följd av användningen av webbplatsen</li>
                <li>Är inte skyldiga att uppdatera informationen i realtid</li>
            </ul>
        </section>

        <!-- External Links -->
        <section class="mb-10">
            <h2 class="text-xl font-semibold text-slate-800">6. Externa länkar</h2>
            <p>Vår webbplats innehåller länkar till externa webbplatser, inklusive:</p>
            <ul class="list-disc pl-6 space-y-1 text-slate-600">
                <li>Skatteverket (skatteverket.se)</li>
                <li>Statistiska Centralbyrån (scb.se)</li>
                <li>Sveriges Kommuner och Regioner (skr.se)</li>
            </ul>
            <p class="mt-2">Vi ansvarar inte för innehållet på dessa externa webbplatser. Länkarna tillhandahålls för din bekvämlighet och för att ge dig tillgång till officiella källor.</p>
        </section>

        <!-- Updates -->
        <section class="mb-10">
            <h2 class="text-xl font-semibold text-slate-800">7. Uppdateringar</h2>
            <p>Skatteregler, avdrag och lönestatistik kan ändras årligen. Vi strävar efter att hålla informationen uppdaterad, men kan inte garantera att alla uppgifter alltid är aktuella vid tidpunkten för ditt besök.</p>
            <p class="mt-2"><strong>Senaste uppdatering av skattedata:</strong> Januari 2026</p>
        </section>

        <!-- Official Sources -->
        <section class="mb-10">
            <h2 class="text-xl font-semibold text-slate-800">8. Officiella källor</h2>
            <p>För officiell och juridiskt bindande information, vänd dig alltid till:</p>
            
            <div class="grid gap-4 sm:grid-cols-2 mt-6 not-prose">
                <a href="https://www.skatteverket.se" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 p-5 border border-slate-200 rounded-xl hover:border-indigo-300 hover:bg-indigo-50/50 transition-colors group">
                    <div>
                        <p class="font-semibold text-indigo-600 group-hover:underline">Skatteverket</p>
                        <p class="text-sm text-slate-500">Officiella skatteregler</p>
                    </div>
                </a>
                <a href="https://www.scb.se" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 p-5 border border-slate-200 rounded-xl hover:border-indigo-300 hover:bg-indigo-50/50 transition-colors group">
                    <div>
                        <p class="font-semibold text-indigo-600 group-hover:underline">SCB</p>
                        <p class="text-sm text-slate-500">Officiell lönestatistik</p>
                    </div>
                </a>
            </div>
        </section>

        <!-- Contact -->
        <section class="mb-10">
            <h2 class="text-xl font-semibold text-slate-800">9. Kontakt</h2>
            <p>Om du har frågor om denna ansvarsfriskrivning, kontakta oss på <a href="mailto:info@raknalon.se" class="text-indigo-600 hover:underline">info@raknalon.se</a>.</p>
        </section>

        <!-- Acceptance -->
        <div class="not-prose bg-slate-100 rounded-xl p-6 text-center">
            <p class="text-slate-600">Genom att använda raknalon.se godkänner du villkoren i denna ansvarsfriskrivning.</p>
        </div>

        <!-- Related Links -->
        <div class="not-prose mt-10 bg-slate-50 rounded-xl p-6">
            <h3 class="font-semibold text-slate-800 mb-3">Relaterade sidor</h3>
            <ul class="space-y-2">
                <li>
                    <a href="/integritetspolicy" class="text-indigo-600 hover:underline">Integritetspolicy</a>
                </li>
                <li>
                    <a href="/sa-raknar-vi" class="text-indigo-600 hover:underline">Så räknar vi (Metodbeskrivning)</a>
                </li>
                <li>
                    <a href="/om-oss" class="text-indigo-600 hover:underline">Om oss</a>
                </li>
            </ul>
        </div>

    </article>
</div>
{% endblock %}

