{% extends "home.twig" %}

{% block head_extra %}
<meta name="robots" content="index, follow">
{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto px-4 py-12 sm:py-16">
    <article class="prose prose-slate prose-lg max-w-none">
        
        <!-- Header -->
        <div class="not-prose mb-10">
            <nav class="flex mb-4" aria-label="Breadcrumb">
                <ol class="flex items-center space-x-2 text-sm text-slate-500">
                    <li><a href="/" class="hover:text-indigo-600">Hem</a></li>
                    <li><span class="mx-2">/</span></li>
                    <li class="text-slate-900 font-medium">Om oss</li>
                </ol>
            </nav>
            <h1 class="text-3xl sm:text-4xl font-bold text-slate-900">Om Raknalon.se</h1>
        </div>

        <!-- Mission Hero -->
        <div class="not-prose bg-gradient-to-r from-indigo-50 to-slate-50 rounded-xl p-6 sm:p-8 mb-10">
            <h2 class="text-xl font-semibold text-slate-900 mb-2">Vår mission</h2>
            <p class="text-slate-600 text-lg">Att hjälpa alla svenskar förstå sin lön, sina skatter och hur mycket de faktiskt får behålla. Vi gör komplexa skatteregler enkla att förstå.</p>
        </div>

        <!-- Why Raknalon -->
        <section class="mb-10">
            <h2 class="text-xl font-semibold text-slate-800">Varför Raknalon.se?</h2>
            <p>Att förstå sin lön efter skatt borde inte vara komplicerat. Ändå finns det tusentals svenskar som varje månad undrar: <em>"Vad blir kvar av min lön?"</em></p>
            <p>Raknalon.se skapades för att ge dig snabba, pålitliga svar. Vår kalkylator tar hänsyn till:</p>
            <ul class="list-disc pl-6 space-y-1 text-slate-600">
                <li><strong class="text-slate-800">Din kommuns skattesats</strong> – vi har alla 290 kommuner</li>
                <li><strong class="text-slate-800">Jobbskatteavdraget</strong> – uppdaterat för 2026</li>
                <li><strong class="text-slate-800">Statlig inkomstskatt</strong> – om du tjänar över brytpunkten</li>
                <li><strong class="text-slate-800">Din ålder</strong> – för korrekt beräkning av jobbskatteavdrag</li>
            </ul>
        </section>

        <!-- Our Sources -->
        <section class="mb-10">
            <h2 class="text-xl font-semibold text-slate-800">Våra källor</h2>
            <p>Vi tar noggrannhet på allvar. Alla våra beräkningar och statistik baseras på officiella källor:</p>
            
            <div class="grid gap-4 sm:grid-cols-2 mt-6 not-prose">
                <a href="https://www.skatteverket.se" target="_blank" rel="noopener noreferrer" class="block border border-slate-200 rounded-xl p-5 hover:border-indigo-300 hover:bg-indigo-50/50 transition-colors group">
                    <span class="font-semibold text-indigo-600 group-hover:underline">Skatteverket</span>
                    <p class="text-sm text-slate-600 mt-2">Officiella skattesatser, jobbskatteavdrag och brytpunkter för statlig skatt.</p>
                </a>
                
                <a href="https://www.scb.se" target="_blank" rel="noopener noreferrer" class="block border border-slate-200 rounded-xl p-5 hover:border-indigo-300 hover:bg-indigo-50/50 transition-colors group">
                    <span class="font-semibold text-indigo-600 group-hover:underline">SCB</span>
                    <p class="text-sm text-slate-600 mt-2">Statistiska Centralbyrån – lönestatistik per yrke och bransch.</p>
                </a>
                
                <a href="https://skr.se" target="_blank" rel="noopener noreferrer" class="block border border-slate-200 rounded-xl p-5 hover:border-indigo-300 hover:bg-indigo-50/50 transition-colors group">
                    <span class="font-semibold text-indigo-600 group-hover:underline">SKR</span>
                    <p class="text-sm text-slate-600 mt-2">Sveriges Kommuner och Regioner – kommunala skattesatser för alla 290 kommuner.</p>
                </a>
                
                <div class="block border border-slate-200 rounded-xl p-5">
                    <span class="font-semibold text-slate-700">Kollektivavtal</span>
                    <p class="text-sm text-slate-600 mt-2">Officiella lönetariffer och avtal för olika yrkesgrupper och branscher.</p>
                </div>
            </div>
        </section>

        <!-- How We Calculate -->
        <section class="mb-10">
            <h2 class="text-xl font-semibold text-slate-800">Så här räknar vi</h2>
            <p>Vår kalkylator följer Sveriges skatteregler för 2026:</p>
            
            <div class="bg-slate-100 rounded-lg p-4 my-4 not-prose">
                <p class="font-mono text-slate-700 text-center">
                    <span class="text-emerald-600 font-bold">Nettolön</span> = Bruttolön − Kommunalskatt − Statlig skatt + Jobbskatteavdrag
                </p>
            </div>
            
            <p>Vi uppdaterar våra beräkningar varje år när Skatteverket publicerar nya regler. All data för 2026 är baserad på de senaste officiella siffrorna.</p>
            
            <p>Vill du veta mer om hur vi räknar? Läs vår detaljerade <a href="/sa-raknar-vi" class="text-indigo-600 hover:underline">metodbeskrivning</a>.</p>
        </section>

        <!-- Important Notice -->
        <section class="mb-10">
            <h2 class="text-xl font-semibold text-slate-800">Viktigt att veta</h2>
            
            <div class="bg-amber-50 border-l-4 border-amber-400 p-5 rounded-r-lg not-prose">
                <p class="font-semibold text-amber-800 mb-2">Observera</p>
                <p class="text-amber-700">Våra beräkningar är uppskattningar och ersätter inte professionell rådgivning. Din faktiska lön kan påverkas av förmåner, avdrag och andra faktorer som vårt verktyg inte beaktar.</p>
                <p class="text-amber-700 mt-2">För exakta uppgifter, kontakta <a href="https://www.skatteverket.se" class="text-amber-800 underline hover:no-underline" target="_blank" rel="noopener noreferrer">Skatteverket</a> eller en auktoriserad revisor.</p>
            </div>
        </section>

        <!-- What We Offer -->
        <section class="mb-10">
            <h2 class="text-xl font-semibold text-slate-800">Vad vi erbjuder</h2>
            
            <div class="grid gap-4 sm:grid-cols-3 mt-4 not-prose">
                <div class="text-center p-4 border border-slate-200 rounded-xl">
                    <h3 class="font-semibold text-slate-800 mb-1">Lönekalkylator</h3>
                    <p class="text-sm text-slate-600">Räkna ut din nettolön baserat på din kommun och inkomst.</p>
                </div>
                <div class="text-center p-4 border border-slate-200 rounded-xl">
                    <h3 class="font-semibold text-slate-800 mb-1">Lönestatistik</h3>
                    <p class="text-sm text-slate-600">Se vad olika yrken tjänar i snitt i Sverige.</p>
                </div>
                <div class="text-center p-4 border border-slate-200 rounded-xl">
                    <h3 class="font-semibold text-slate-800 mb-1">Guider</h3>
                    <p class="text-sm text-slate-600">Lär dig om skatter, jobbskatteavdrag och mer.</p>
                </div>
            </div>
        </section>

        <!-- Contact -->
        <section class="mb-10">
            <h2 class="text-xl font-semibold text-slate-800">Kontakta oss</h2>
            <p>Har du frågor, feedback eller hittat ett fel? Vi vill gärna höra från dig!</p>
            
            <div class="bg-slate-50 rounded-xl p-5 mt-4 not-prose">
                <p class="font-semibold text-slate-800">E-post</p>
                <a href="mailto:info@raknalon.se" class="text-indigo-600 hover:underline">info@raknalon.se</a>
                <p class="text-sm text-slate-500 mt-3">Vi svarar vanligtvis inom 24 timmar.</p>
            </div>
        </section>

        <!-- Trust Badges -->
        <div class="not-prose border-t border-slate-200 pt-8 mt-10">
            <div class="flex flex-wrap justify-center gap-6 text-sm text-slate-500">
                <span>HTTPS-krypterad</span>
                <span>Svenskutvecklad</span>
                <span>Uppdaterad 2026</span>
                <span>100% gratis</span>
            </div>
        </div>

        <!-- CTA -->
        <div class="not-prose mt-10">
            <div class="bg-gradient-to-r from-indigo-50 to-slate-50 rounded-xl p-6 text-center">
                <p class="text-slate-600 mb-4">Redo att räkna ut din lön?</p>
                <a href="/" class="inline-flex items-center gap-2 bg-indigo-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-indigo-700 transition-colors">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                    </svg>
                    Till kalkylatorn
                </a>
            </div>
        </div>

    </article>
</div>
{% endblock %}
