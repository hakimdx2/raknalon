								<script>
									document.addEventListener('DOMContentLoaded', function () {
const ctxForecast = document.getElementById('salaryForecastChart');
if (ctxForecast) {
const currentYear = '{{ profession.forecast.current_year }}';
const currentValue = {{ profession.forecast.current_value }};

const labels = [currentYear,{% for item in profession.forecast.data %}'{{ item.year }}'{% if not loop.last %},{% endif %}{% endfor %}];
const data = [currentValue,{% for item in profession.forecast.data %}{{ item.value }}{% if not loop.last %},{% endif %}{% endfor %}];

new Chart(ctxForecast, {
type: 'line',
data: {
labels: labels,
datasets: [
{
label: 'Löneprognos',
data: data,
borderColor: 'rgb(16, 185, 129)', // Emerald-500
backgroundColor: 'rgba(16, 185, 129, 0.1)',
fill: true,
tension: 0.4,
pointBackgroundColor: 'rgb(16, 185, 129)',
pointBorderColor: '#fff',
pointBorderWidth: 2,
pointRadius: 5,
pointHoverRadius: 7
}
]
},
options: {
responsive: true,
maintainAspectRatio: false,
plugins: {
legend: {
display: false
},
tooltip: {
callbacks: {
label: function (context) {
return context.parsed.y.toLocaleString('sv-SE') + ' kr';
}
}
},
annotation: {
annotations: {
line1: {
type: 'line',
yMin: currentValue,
yMax: currentValue,
borderColor: 'rgba(0,0,0,0.1)',
borderWidth: 1,
borderDash: [
5, 5
],
label: {
content: 'Idag',
enabled: true,
position: 'start'
}
}
}
}
},
scales: {
y: {
beginAtZero: false,
grid: {
display: true,
borderDash: [
2, 4
],
color: 'rgba(0,0,0,0.05)'
},
ticks: {
callback: function (value) {
return value.toLocaleString('sv-SE') + ' kr';
}
}
},
x: {
grid: {
display: false
}
}
}
}
});
}
});
								</script>

