{% extends "home.twig" %}

{% set months_sv = {'01': 'Januari', '02': 'Februari', '03': 'Mars', '04': 'April', '05': 'Maj', '06': 'Juni', '07': 'Juli', '08': 'Augusti', '09': 'September', '10': 'Oktober', '11': 'November', '12': 'December'} %}
{% set current_month_sv = months_sv["now"|date("m")] %}
{% set title = 'Lön ' ~ profession.title ~ ' 2026 (' ~ current_month_sv ~ ') - Statistik & Lön' %}

{% block head_extra %}
	<!-- Occupation Schema.org - Enriched with SCB Data -->
	<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
	<script type="application/ld+json">
		{
																																																																																		    "@context": "https://schema.org",
																																																																																		    "@type": "Occupation",
																																																																																		    "name": "{{ profession.title }}",
																																																																																		    "description": "{{ profession.description|e('js') }}",
		{% if profession.scb is defined and profession.scb.ssyk_code is defined %}
			"occupationalCategory": "{{ profession.scb.ssyk_code }}",
		{% endif %}
		"occupationLocation": {
																																																																																		        "@type": "Country",
																																																																																		        "name": "Sweden",
																																																																																		        "sameAs": "https://sv.wikipedia.org/wiki/Sverige"
																																																																																		    },
																																																																																		    "estimatedSalary": {
																																																																																		        "@type": "MonetaryAmountDistribution",
																																																																																		        "name": "Månadslön",
																																																																																		        "currency": "SEK",
																																																																																		        "duration": "P1M",
		{% if profession.scb is defined and profession.scb.salary_total > 0 %}
			"median":
			{{ profession.scb.salary_total }},
																																																																																																																											        "percentile10":
			{{ profession.scb.percentiles.p10 > 0 ? profession.scb.percentiles.p10 : (profession.median_salary * 0.7)|round }},
																																																																																																																											        "percentile25":
			{{ profession.scb.percentiles.p25 > 0 ? profession.scb.percentiles.p25 : (profession.median_salary * 0.85)|round }},
																																																																																																																											        "percentile75":
			{{ profession.scb.percentiles.p75 > 0 ? profession.scb.percentiles.p75 : (profession.avg_salary * 1.15)|round }},
																																																																																																																											        "percentile90":
			{{ profession.scb.percentiles.p90 > 0 ? profession.scb.percentiles.p90 : (profession.avg_salary * 1.35)|round }}
		{% else %}
			"median":
			{{ profession.median_salary }},
																																																																																																																											        "percentile25":
			{{ (profession.median_salary * 0.85)|round }},
																																																																																																																											        "percentile75":
			{{ (profession.avg_salary * 1.15)|round }}
		{% endif %}
		},
																																																																																		    "educationRequirements": "{{ profession.education|e('js') }}",
																																																																																		    "qualifications": "{{ profession.education|e('js') }}"
																																																																																		}
	</script>

	{% if profession.scb is defined and profession.scb.salary_men > 0 and profession.scb.salary_women > 0 %}
		<!-- FAQPage Schema.org for SCB Data -->
		<script type="application/ld+json">
			{
																																																																																																																											    "@context": "https://schema.org",
																																																																																																																											    "@type": "FAQPage",
																																																																																																																											    "mainEntity": [
																																																																																																																											        {
																																																																																																																											            "@type": "Question",
																																																																																																																											            "name": "Vad är medellönen för en
			{{ profession.title|lower }}
			{{ profession.scb.year }}?",
																																																																																																																											            "acceptedAnswer": {
																																																																																																																											                "@type": "Answer",
																																																																																																																											                "text": "Enligt SCB:s officiella statistik är medellönen för en
			{{ profession.title|lower }}
			{{ profession.scb.salary_total|number_format(0, ' ', ' ') }}
			kr per månad ({{ profession.scb.year }})."
																																																																																																																											            }
																																																																																																																											        },
																																																																																																																											        {
																																																																																																																											            "@type": "Question",
																																																																																																																											            "name": "Tjänar män eller kvinnor mer som
			{{ profession.title|lower }}?",
																																																																																																																											            "acceptedAnswer": {
																																																																																																																											                "@type": "Answer",
																																																																																																																											                "text": "Män tjänar i genomsnitt
			{{ profession.scb.salary_men|number_format(0, ' ', ' ') }}
			kr medan kvinnor tjänar
			{{ profession.scb.salary_women|number_format(0, ' ', ' ') }}
			kr. Kvinnor tjänar
			{{ profession.scb.gender_gap_percent }}% av mäns lön."
																																																																																																																											            }
																																																																																																																											        }
			{% if profession.scb.evolution_10y_percent is defined %},
																																																																																																																																																																				        {
																																																																																																																																																																				            "@type": "Question",
																																																																																																																																																																				            "name": "Hur har lönen för
				{{ profession.title|lower }}
				utvecklats?",
																																																																																																																																																																				            "acceptedAnswer": {
																																																																																																																																																																				                "@type": "Answer",
																																																																																																																																																																				                "text": "Lönen för
				{{ profession.title|lower }}
				har ökat med
				{{ profession.scb.evolution_10y_percent }}% under de senaste 10 åren (2014-2024), enligt SCB."
																																																																																																																																																																				            }
																																																																																																																																																																				        }
			{% endif %}
			]
																																																																																																																											}
		</script>
	{% endif %}

	<!-- Article Schema for Freshness & EEAT Signals (Leak Tier 2) -->
	<script type="application/ld+json">
		{
																																																										        "@context": "https://schema.org",
																																																										        "@type": "Article",
																																																										        "headline": "{{ profession.title }}
		Lön 2026 - Lönestatistik & Ingångslön",
																																																										        "datePublished": "2026-01-01",
																																																										        "dateModified": "{{ "now"|date("Y-m-d") }}",
																																																										        "author": {
																																																										            "@type": "Organization",
																																																										            "name": "Räkna Lön",
																																																										            "url": "https://raknalon.se"
																																																										        },
																																																										        "publisher": {
																																																										            "@type": "Organization",
																																																										            "name": "Räkna Lön",
																																																										            "logo": {
																																																										                "@type": "ImageObject",
																																																										                "url": "https://raknalon.se/img/logo-new.svg"
																																																										            }
																																																										        },
																																																										        "image": "https://raknalon.se{{ profession.banner_image|default('/img/professions/default-banner.webp') }}",
																																																										        "mainEntityOfPage": {
																																																										            "@type": "WebPage",
																																																										            "@id": "https://raknalon.se/lon/{{ profession.slug }}"
																																																										        }
																																																										    }
	</script>

	<!-- BreadcrumbList Schema.org -->
	<script type="application/ld+json">
		{
																																																																																		    "@context": "https://schema.org",
																																																																																		    "@type": "BreadcrumbList",
																																																																																		    "itemListElement": [
																																																																																		        {
																																																																																		            "@type": "ListItem",
																																																																																		            "position": 1,
																																																																																		            "name": "Hem",
																																																																																		            "item": "https://raknalon.se/"
																																																																																		        },
																																																																																		        {
																																																																																		            "@type": "ListItem",
																																																																																		            "position": 2,
																																																																																		            "name": "Yrken",
																																																																																		            "item": "https://raknalon.se/yrken"
																																																																																		        },
																																																																																		        {
																																																																																		            "@type": "ListItem",
																																																																																		            "position": 3,
																																																																																		            "name": "{{ profession.category|default('Allmänt') }}",
																																																																																		            "item": "https://raknalon.se/yrken#{{ profession.category|default('Allmänt')|lower|replace({' ': '-', '&': ''}) }}"
																																																																																		        },
																																																																																		        {
																																																																																		            "@type": "ListItem",
																																																																																		            "position": 4,
																																																																																		            "name": "{{ profession.title }}",
																																																																																		            "item": "https://raknalon.se/lon/{{ profession.slug }}"
																																																																																		        }
																																																																																		    ]
																																																																																		}
	</script>
{% endblock %}

{% block content %}
	{% include 'partials/ads/config.twig' %}
	<div class="bg-slate-50 min-h-screen pb-20">
		<div
			class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

			<!-- Breadcrumb -->
			<nav class="flex mb-8" aria-label="Breadcrumb">
				<ol role="list" class="flex items-center space-x-2">
					<li>
						<a href="/" class="text-sm font-medium text-slate-500 hover:text-indigo-600">Hem</a>
					</li>
					<li>
						<span class="text-slate-300">/</span>
					</li>
					<li>
						<a href="/yrken" class="text-sm font-medium text-slate-500 hover:text-indigo-600">Yrken</a>
					</li>
					<li>
						<span class="text-slate-300">/</span>
					</li>
					<li>
						<span class="text-sm font-medium text-slate-500">{{ profession.category|default('Allmänt') }}</span>
					</li>
					<li>
						<span class="text-slate-300">/</span>
					</li>
					<li>
						<span class="text-sm font-medium text-indigo-600" aria-current="page">{{ profession.title }}</span>
					</li>
				</ol>
			</nav>

			<!-- Header -->
			<div class="text-center mb-12">
				<div class="flex flex-col items-center justify-center gap-4 mb-8">
					<div class="flex items-center justify-center gap-2">
						<span class="inline-flex items-center rounded-md bg-indigo-50 px-2.5 py-1 text-xs font-medium text-indigo-700 ring-1 ring-inset ring-indigo-700/10">
							Lönestatistik 2026
						</span>
						{% if profession.category %}
							<span class="inline-flex items-center rounded-md bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-600 ring-1 ring-inset ring-slate-500/10">
								{{ profession.category }}
							</span>
						{% endif %}
					</div>
				</div>
				<h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-5xl mb-4">
					Hur mycket tjänar en
					{{ profession.title }}?
				</h1>

				<!-- Ezoic 102: under_page_title -->
				<!-- AdSense: Top (High Visibility) -->
				{% include 'partials/ads/display.twig' with {'slot_name': 'profession_top'} %}
				<p class="text-sm text-slate-500 mb-6 font-medium">
					<svg class="w-4 h-4 inline-block mr-1 -mt-0.5" fill="none" stroke="currentColor" viewbox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
					</svg>
					Senast uppdaterad:
					{{ "now"|date("j F Y") | replace({'January': 'januari', 'February': 'februari', 'March': 'mars', 'April': 'april', 'May': 'maj', 'June': 'juni', 'July': 'juli', 'August': 'augusti', 'September': 'september', 'October': 'oktober', 'November': 'november', 'December': 'december'}) }}
				</p>

				<!-- Author E-E-A-T (Top) -->
				{% if profession.author %}
					<a href="/om-oss/nala" class="group flex items-center justify-center gap-3 mb-6 mt-2 hover:bg-slate-50 p-2 rounded-lg transition-colors">
						<img src="{{ profession.author.image }}" alt="{{ profession.author.name }}" class="h-10 w-10 rounded-full object-cover ring-2 ring-white shadow-sm group-hover:ring-indigo-200 transition-all" style="
																																																																																																																																																																																																											    border: 2px solid #0f172a6e;
																																																																																																																																																																																																											">
						<div class="text-left">
							<p class="text-sm font-bold text-slate-900 leading-none group-hover:text-indigo-700 transition-colors">{{ profession.author.name }}</p>
							<p class="text-xs text-slate-500 font-medium group-hover:text-indigo-500 transition-colors">{{ profession.author.role }}</p>
						</div>
					</a>
				{% endif %}
				<p class="text-lg text-slate-600 max-w-2xl mx-auto mb-8">
					Se aktuell lönestatistik, utbildningskrav och räkna ut vad en
					{{ profession.title|lower }}
					får ut efter skatt.
				</p>
				<div class="flex justify-center">
					<button onclick="document.getElementById('calculator').scrollIntoView({behavior: 'smooth'})" class="inline-flex items-center gap-2 rounded-full bg-indigo-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-all">
						<svg class="h-5 w-5" viewbox="0 0 20 20" fill="currentColor" aria-hidden="true">
							<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-11.25a.75.75 0 00-1.5 0v2.5h-2.5a.75.75 0 000 1.5h2.5v2.5a.75.75 0 001.5 0v-2.5h2.5a.75.75 0 000-1.5h-2.5v-2.5z" clip-rule="evenodd"/>
						</svg>
						Räkna ut lön efter skatt
					</button>
				</div>
			</div>

			<!-- Stats Grid -->
			<div
				class="grid grid-cols-1 gap-5 sm:grid-cols-3 mb-12">
				<!-- Snittlön (SCB or fallback) -->
				<div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-slate-900/5 px-6 py-6">
					<dt class="truncate text-sm font-medium text-slate-500">Snittlön</dt>
					{% if profession.scb is defined and profession.scb.salary_total > 0 %}
						<dd class="mt-2 text-3xl font-bold tracking-tight text-slate-900">{{ profession.scb.salary_total|number_format(0, ',', ' ') }}
							kr</dd>
						<dd class="mt-2 text-sm text-slate-500">Privat sektor (SCB
							{{ profession.scb.year }})</dd>
					{% else %}
						<dd class="mt-2 text-3xl font-bold tracking-tight text-slate-900">{{ profession.avg_salary|number_format(0, ',', ' ') }}
							kr</dd>
						<dd class="mt-2 text-sm text-slate-500">Genomsnitt i Sverige</dd>
					{% endif %}
				</div>
				<!-- Median -->
				<div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-slate-900/5 px-6 py-6">
					<dt class="truncate text-sm font-medium text-slate-500">Medianlön</dt>
					<dd class="mt-2 text-3xl font-bold tracking-tight text-slate-900">{{ profession.median_salary|number_format(0, ',', ' ') }}
						kr</dd>
					<dd class="mt-2 flex items-center text-sm text-emerald-600 font-medium">
						<svg class="h-4 w-4 mr-1" viewbox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12 7a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0V8.414l-4.293 4.293a1 1 0 01-1.414 0L8 10.414l-4.293 4.293a1 1 0 01-1.414-1.414l5-5a1 1 0 011.414 0L8.586 10l-4.293 4.293z" clip-rule="evenodd"/></svg>
						Vanligaste lönen
					</dd>
				</div>
				<!-- Löneutveckling or Efterfrågan -->
				<div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-slate-900/5 px-6 py-6">
					{% if profession.scb is defined and profession.scb.evolution_10y_percent %}
						<dt class="truncate text-sm font-medium text-slate-500">Löneutveckling</dt>
						<dd class="mt-2 text-3xl font-bold tracking-tight text-emerald-600">+{{ profession.scb.evolution_10y_percent }}%</dd>
						<dd class="mt-2 text-sm text-slate-500">Senaste 10 åren</dd>
					{% else %}
						<dt class="truncate text-sm font-medium text-slate-500">Efterfrågan</dt>
						<dd class="mt-2 text-3xl font-bold tracking-tight text-slate-900">Hög</dd>
						<dd class="mt-2 text-sm text-slate-500">Framtidsutsikter: Goda</dd>
					{% endif %}
				</div>
			</div>


			<!-- Grid Layout: Main Content + Sticky TOC -->
			<div id="toc-grid" class="lg:grid lg:grid-cols-[1fr_240px] lg:gap-8">

				<!-- Changing target to sidebar col which is likely later, wait. The code snippet shows `lg:grid-cols-[1fr_240px]`. The first div is the main col. The second div (sidebar) is missing in the visible snippet 302-317. I need to scroll down to find the right column. -->
				<!-- Correction: I will use a different anchor. Line 327 is introduction. -->

					<div class="lg:col-start-1"> {# ============================================== #}
					{# BLOC SCB 1: Source Officielle + Gender Gap    #}
					{# ============================================== #}
					{% include 'partials/scb_gender_gap.twig' %}


					<!-- Calculator Embed -->
					{% include 'partials/salary_calculator.twig' %}
					{# {% include 'partials/salary_barometer.twig' %} #}
					{% include 'partials/scb_salary_chart.twig' %}


					<!-- Content & FAQ Combined -->
						<article id="om-yrket" class="prose prose-lg prose-indigo w-full max-w-none bg-white p-8 sm:p-12 rounded-2xl shadow-sm ring-1 ring-slate-900/5 prose-p:leading-loose prose-li:leading-loose" style="position: relative;"> {% if profession.banner_image %}
							<div style="position: absolute; top: -80px; right: 0; max-width: 150px; z-index: 999;">
								<img src="{{ profession.banner_image }}" alt="{{ profession.title }}" class="w-full h-auto">
							</div>
						{% endif %}

						<h2 class="mt-0">Om yrket
							{{ profession.title }}</h2>

						<p class="text-lg text-slate-700 leading-loose mb-8">{{ profession.description|raw }}</p>

						<!-- Ezoic 109: under_first_paragraph -->
						<!-- AdSense: In-Article (Native) -->
						{% include 'partials/ads/in_article.twig' with {'slot_name': 'profession_in_article'} %}

						<!-- In-Content CTA (High Conversion) -->


						{% if profession.description_extended %}
							<p class="text-slate-600 leading-loose mb-8">{{ profession.description_extended|raw }}</p>
						{% endif %}

						{% if profession.content_images[0] is defined %}
							<figure class="my-8 rounded-2xl overflow-hidden shadow-lg ring-1 ring-slate-900/5">
								<img src="{{ profession.content_images[0].src }}" alt="{{ profession.content_images[0].alt|default(profession.title ~ ' arbetsplats') }}" loading="lazy" class="w-full h-auto object-cover transform hover:scale-[1.02] transition-transform duration-500">
								{% if profession.content_images[0].caption is defined %}
									<figcaption class="mt-0 text-sm text-center text-slate-500 py-3 bg-slate-50 border-t border-slate-100 italic">{{ profession.content_images[0].caption }}</figcaption>
								{% endif %}
							</figure>
						{% endif %}


						{% if profession.pros and profession.cons %}
							<h3 id="fordelar-nackdelar">Fördelar och nackdelar</h3>
							<div
								class="grid md:grid-cols-2 gap-x-12 gap-y-8 my-8">
								<!-- Pros -->
								<div>
									<h4 class="text-slate-900 font-bold mb-4 flex items-center gap-2 text-lg mt-0">
										Fördelar
									</h4>
									<ul class="space-y-2 m-0 mt-4 pl-5 list-disc marker:text-emerald-500">
										{% for pro in profession.pros %}
											<li class="text-slate-700 m-0 p-0 pl-1">
												<span>{{ pro }}</span>
											</li>
										{% endfor %}
									</ul>
								</div>

								<!-- Cons -->
								<div>
									<h4 class="text-slate-900 font-bold mb-4 flex items-center gap-2 text-lg mt-0">
										Utmaningar
									</h4>
									<ul class="space-y-2 m-0 mt-4 pl-5 list-disc marker:text-amber-500">
										{% for con in profession.cons %}
											<li class="text-slate-700 m-0 p-0 pl-1">
												<span>{{ con }}</span>
											</li>
										{% endfor %}
									</ul>
								</div>
							</div>
						{% endif %}

						<!-- In-Content CTA (High Conversion / Premium Dark) -->
						<div
							class="my-12 relative overflow-hidden rounded-2xl bg-slate-900 p-8 shadow-2xl ring-1 ring-white/10 not-prose group">
							<!-- Background Effects -->
							<div class="absolute top-0 right-0 -mt-10 -mr-10 w-40 h-40 bg-indigo-500 rounded-full blur-3xl opacity-20 group-hover:opacity-30 transition-opacity duration-700"></div>
							<div class="absolute bottom-0 left-0 -mb-10 -ml-10 w-40 h-40 bg-orange-500 rounded-full blur-3xl opacity-10 group-hover:opacity-20 transition-opacity duration-700"></div>

							<div class="relative z-10 grid gap-8 md:grid-cols-[1.5fr_1fr] md:items-center">
								<div>
									<div class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-xs font-bold text-orange-300 ring-1 ring-inset ring-white/20 mb-4 backdrop-blur-sm">
										<span class="flex h-1.5 w-1.5 rounded-full bg-orange-400 animate-pulse"></span>
										LÖNE-HACK 2026
									</div>
									<h3 class="text-2xl font-bold text-white mb-3 tracking-tight leading-tight">
										Är du en underbetald
