				<style>
@media(min-width: 1024px) {
	#toc-sidebar {
		display: block !important;
	}
	#toc-grid {
		display: grid !important;
		grid-template-columns: 1fr 240px;
		gap: 2rem;
	}
}
.toc-link:hover {
	color: rgb(79, 70, 229);
	border-left-color: rgb(79, 70, 229);
}
.toc-link.active {
	color: rgb(79, 70, 229) !important;
	border-left-color: rgb(79, 70, 229) !important;
	font-weight: 600;
}

/* Heading anchor links */
article h2[id],
article h3[id],
article h4[id] {
	position: relative;
}
article h2[id]:before,
article h3[id]:before,
article h4[id]:before {
	content: "#";
	position: absolute;
	left: -1.5rem;
	color: rgb(79, 70, 229);
	opacity: 1;
	cursor: pointer;
}

/* List bullets color */
article ul > li::marker {
	color: rgb(79, 70, 229) !important;
}

article h2[id] a.anchor-link,
article h3[id] a.anchor-link,
article h4[id] a.anchor-link {
	position: absolute;
	left: -1.5rem;
	color: rgb(79, 70, 229);
	text-decoration: none;
	opacity: 0;
	transition: opacity 0.2s ease;
}
article h2[id]:hover a.anchor-link,
article h3[id]:hover a.anchor-link,
article h4[id]:hover a.anchor-link {
	opacity: 1;
}
			</style>

				<script>
// Smooth scroll and active section tracking for TOC
document.addEventListener('DOMContentLoaded', function () {
const tocLinks = document.querySelectorAll('.toc-link');
const sections = document.querySelectorAll('[id]');

// Smooth scroll
tocLinks.forEach(link => {
link.addEventListener('click', function (e) {
e.preventDefault();
const targetId = this.getAttribute('data-target');
const targetSection = document.getElementById(targetId);
if (targetSection) {
targetSection.scrollIntoView({behavior: 'smooth', block: 'start'});
// Manually set active class on click to avoid lag
tocLinks.forEach(l => l.classList.remove('active'));
this.classList.add('active');
}
});
});

// Track active section with IntersectionObserver
const observerOptions = {
root: null,
rootMargin: '-10% 0px -70% 0px', // Adjusted to trigger earlier/better
threshold: 0
};

const observerCallback = (entries) => {
entries.forEach(entry => {
if (entry.isIntersecting) {
const activeId = entry.target.id;
tocLinks.forEach(link => {
link.classList.remove('active');
if (link.getAttribute('data-target') === activeId) {
link.classList.add('active');
}
});
}
});
};

const observer = new IntersectionObserver(observerCallback, observerOptions);

// Add all tracked section IDs here
const trackedSections = [
'om-yrket',
'fordelar-nackdelar',
'utbildning',
'loneprognos',
'loneutveckling-history',
'erfarenhet',
'specialisering',
'sektor',
'arbetsplats',
'arbetsgivare',
'typ-av-trafik',
'lonestatistik',
'lon-alder',
'lon-region',
'lonefordelning',
'faq'
];

trackedSections.forEach(id => {
const section = document.getElementById(id);
if (section) {
observer.observe(section);
}
});
});
			</script>

