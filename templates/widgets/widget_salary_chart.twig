{# 
  Widget Salary Chart - Pixel-Perfect Match avec design de référence
  Utilise Tailwind CSS + Alpine.js
#}

{% set salary = salary|default({q1: 0, q2: 0, q3: 0, currency: 'kr', hasData: false, isMonthly: true}) %}
{% set config = config|default({showBonus: false, showSwitch: true, showComments: false, commentsCount: 0, infoLink: ''}) %}
{% set labels = labels|default({
    yearly: 'Årslön',
    monthly: 'Månadslön', 
    withBonus: 'Med bonus',
    marketSalary: 'Marknadslön',
    perYear: 'Brutto/År',
    perMonth: 'Brutto/Månad',
    lessText: '25% tjänar mindre än',
    moreText: '25% tjänar mer än',
    noData: 'Inte tillräckligt med data',
    infoText: 'Alla marknadslöner baseras på heltidstjänst.',
    infoLinkText: 'Läs mer om hur vi räknar.'
}) %}

<div
	id="salary-chart" class="salary-chart-widget" x-data="salaryChartWidget({
		         q1: {{ salary.q1|default(0) }},
		         q2: {{ salary.q2|default(0) }},
		         q3: {{ salary.q3|default(0) }},
		         currency: '{{ salary.currency|default('kr') }}',
		         hasData: {{ salary.hasData|default(false) ? 'true' : 'false' }},
		         isMonthly: {{ salary.isMonthly|default(true) ? 'true' : 'false' }},
		         locale: '{{ salary.locale|default('sv-SE') }}',
		         labels: {
		             perYear: '{{ labels.perYear }}',
		             perMonth: '{{ labels.perMonth }}'
		         }
		     })">

	{# ========== CONTROLS: Toggle + Bonus ========== #}
	{% if config.showSwitch or config.showBonus %}
		<div
			class="flex items-center justify-center gap-6 mb-6">

			{# Toggle Switch - Exact match with reference #}
			{% if config.showSwitch %}
				<div class="inline-flex rounded-full border border-emerald-200 overflow-hidden">
					<button type="button" class="px-5 py-2.5 text-sm font-semibold transition-all duration-150" :class="unit === 'yearly'
						                        ? 'bg-emerald-50 text-emerald-700'
						                        : 'bg-white text-slate-500 hover:text-slate-700'" @click="unit = 'yearly'">
						{{ labels.yearly }}
					</button>
					<button type="button" class="px-5 py-2.5 text-sm font-semibold transition-all duration-150 border-l border-emerald-200" :class="unit === 'monthly'
						                        ? 'bg-emerald-50 text-emerald-700'
						                        : 'bg-white text-slate-500 hover:text-slate-700'" @click="unit = 'monthly'">
						{{ labels.monthly }}
					</button>
				</div>
			{% endif %}

			{# Bonus Checkbox - Green checkmark style #}
			{% if config.showBonus %}
				<button
					type="button" class="inline-flex items-center gap-2.5 px-4 py-2.5 rounded-full border transition-all duration-150 text-sm font-semibold" :class="withBonus
						                    ? 'bg-emerald-50 border-emerald-200 text-emerald-700'
						                    : 'bg-white border-emerald-200 text-slate-500 hover:text-slate-700'" @click="withBonus = !withBonus">
					{# Checkmark circle #}
					<span class="relative flex items-center justify-center w-5 h-5 rounded-full border-2 transition-all" :class="withBonus ? 'bg-emerald-500 border-emerald-500' : 'bg-white border-emerald-300'">
						<svg x-show="withBonus" class="w-3 h-3 text-white" fill="currentColor" viewbox="0 0 12 12">
							<path d="M10.28 2.28L4 8.56 1.72 6.28a1 1 0 00-1.44 1.44l3 3a1 1 0 001.44 0l7-7a1 1 0 00-1.44-1.44z"/>
						</svg>
					</span>
					<span>{{ labels.withBonus }}</span>
				</button>
			{% endif %}
		</div>
	{% endif %}

	{# ========== MAIN SALARY CARD ========== #}
	<div
		class="relative rounded-[1.5rem] bg-gradient-to-b from-emerald-50 to-emerald-100/50 px-8 py-6 md:px-12 md:py-8">

		{# Market Label - Top Left #}
		<div class="text-emerald-800 font-medium text-base mb-1">
			{{ labels.marketSalary }}
		</div>

		{# Comments Badge - Absolute Top Right #}
		{% if config.showComments and config.commentsCount > 0 %}
			<div class="absolute top-4 right-4 md:top-6 md:right-6">
				<div class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-amber-200 text-amber-900">
					<span class="text-sm font-semibold">{{ labels.comments|default('Kommentarer') }}:</span>
					<span class="text-sm font-semibold">{{ config.commentsCount }}</span>
					<svg class="w-4 h-4" fill="currentColor" viewbox="0 0 24 24">
						<path d="M12 2C6.48 2 2 6.48 2 12c0 1.54.36 2.98.97 4.29L2 22l5.71-.97C9.02 21.64 10.46 22 12 22c5.52 0 10-4.48 10-10S17.52 2 12 2zm0 18c-1.29 0-2.52-.3-3.63-.84l-.26-.14-2.68.46.46-2.68-.14-.26C5.3 15.52 5 14.29 5 13c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7z"/>
					</svg>
				</div>
			</div>
		{% endif %}

		{# ========== CENTRAL VALUE ========== #}
		<div class="flex items-baseline justify-center gap-3 mt-2 mb-4">
			<template x-if="hasData">
				<span class="text-4xl md:text-5xl font-medium text-emerald-900 tracking-tight" x-text="formattedQ2"></span>
			</template>
			<template x-if="hasData">
				<span class="text-lg md:text-xl font-medium text-emerald-800" x-text="unitLabel"></span>
			</template>
			<template x-if="!hasData">
				<span class="text-xl font-medium text-emerald-800 py-4">{{ labels.noData }}</span>
			</template>
		</div>

		{# ========== QUARTILES Q1 / Q3 ========== #}
		<template x-if="hasData">
			<div
				class="flex justify-between items-start mb-2">
				{# Q1 - Left #}
				<div class="text-left">
					<div class="text-emerald-700 text-sm font-medium mb-1">{{ labels.lessText }}</div>
					<div class="text-emerald-900 text-xl md:text-2xl font-medium" x-text="formattedQ1"></div>
				</div>

				{# Q3 - Right #}
				<div class="text-right">
					<div class="text-emerald-700 text-sm font-medium mb-1">{{ labels.moreText }}</div>
					<div class="text-emerald-900 text-xl md:text-2xl font-medium" x-text="formattedQ3"></div>
				</div>
			</div>
		</template>

		{# ========== BELL CURVE SVG ========== #}
		<div
			class="relative -mx-8 md:-mx-12 -mb-6 md:-mb-8">
			{# Grayscale overlay for no data #}
			<template x-if="!hasData">
				<div class="absolute inset-0 backdrop-grayscale pointer-events-none z-10 rounded-b-[1.5rem]"></div>
			</template>

			<svg
				class="w-full h-auto" viewbox="0 0 800 100" fill="none" preserveaspectratio="xMidYMax meet">
				{# Gradient definition #}
				<defs>
					<linearGradient id="bellGradient" x1="400" y1="0" x2="400" y2="100" gradientunits="userSpaceOnUse">
						<stop offset="0%" stop-color="#34d399"/>
						<stop offset="100%" stop-color="#a7f3d0"/>
					</linearGradient>
					<mask id="bellMask">
						<path d="M0 100 C0 85, 10 75, 25 74 C80 70, 150 65, 200 60 C250 55, 300 30, 400 10 C500 30, 550 55, 600 60 C650 65, 720 70, 775 74 C790 75, 800 85, 800 100 Z" fill="white"/>
					</mask>
				</defs>

				{# Bell curve fill #}
				<g mask="url(#bellMask)">
					<rect
					x="0" y="0" width="800" height="100" fill="url(#bellGradient)"/>
					{# Q1 fade area #}
					<rect
					x="0" y="0" width="165" height="100" fill="white" fill-opacity="0.35"/>
					{# Q3 fade area #}
					<rect x="635" y="0" width="165" height="100" fill="white" fill-opacity="0.35"/>
				</g>

				{# Q1 vertical line #}
				<rect
				x="162" y="55" width="4" height="45" rx="2" fill="#10b981"/>
				{# Median (Q2) vertical line #}
				<rect
				x="398" y="5" width="4" height="50" rx="2" fill="#10b981"/>
				{# Q3 vertical line #}
				<rect x="634" y="55" width="4" height="45" rx="2" fill="#10b981"/>
			</svg>
		</div>

		{# ========== INFO TEXT ========== #}
		{% if config.infoLink %}
			<div class="text-center text-slate-500 text-xs mt-6 pt-4">
				{{ labels.infoText }}
				<a href="{{ config.infoLink }}" class="underline hover:text-slate-700">{{ labels.infoLinkText }}</a>
			</div>
		{% endif %}
	</div>
</div>

<script>
	function salaryChartWidget(config) {
return {
q1: config.q1 || 0,
q2: config.q2 || 0,
q3: config.q3 || 0,
currency: config.currency || 'kr',
locale: config.locale || 'sv-SE',
hasData: config.hasData !== false && config.q2 > 0,
isMonthly: config.isMonthly !== false,
unit: 'monthly',
withBonus: true,
labels: config.labels || {
perYear : 'Brutto/År',
perMonth : 'Brutto/Månad'
},

get displayQ1() {
const base = this.q1;
let value = this.isMonthly ? (this.unit === 'yearly' ? base * 12 : base) : (this.unit === 'yearly' ? base : Math.round(base / 12));
return this.withBonus ? value : Math.round(value * 0.9);
},

get displayQ2() {
const base = this.q2;
let value = this.isMonthly ? (this.unit === 'yearly' ? base * 12 : base) : (this.unit === 'yearly' ? base : Math.round(base / 12));
return this.withBonus ? value : Math.round(value * 0.9);
},

get displayQ3() {
const base = this.q3;
let value = this.isMonthly ? (this.unit === 'yearly' ? base * 12 : base) : (this.unit === 'yearly' ? base : Math.round(base / 12));
return this.withBonus ? value : Math.round(value * 0.9);
},

formatNumber(num) {
return num.toLocaleString(this.locale) + ' ' + this.currency;
},

get formattedQ1() {
return this.formatNumber(this.displayQ1);
},
get formattedQ2() {
return this.formatNumber(this.displayQ2);
},
get formattedQ3() {
return this.formatNumber(this.displayQ3);
},

get unitLabel() {
return this.unit === 'yearly' ? this.labels.perYear : this.labels.perMonth;
}
}
}
</script>
