{% extends "home.twig" %}

{% block head_extra %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Lönestatistik för alla yrken i Sverige 2026",
    "description": "Komplett lista över lönestatistik för {{ professions|length }} yrken i Sverige. Se medianlön, snittlön och räkna ut nettolön för varje yrke.",
    "url": "https://raknalon.se/yrken",
    "numberOfItems": {{ professions|length }},
    "mainEntity": {
        "@type": "ItemList",
        "itemListElement": [
            {% for p in professions %}
            {
                "@type": "ListItem",
                "position": {{ loop.index }},
                "url": "https://raknalon.se/lon/{{ p.slug }}",
                "name": "{{ p.title }} lön"
            }{% if not loop.last %},{% endif %}
            {% endfor %}
        ]
    }
}
</script>
{% endblock %}

{% block content %}
<div class="bg-slate-50 pt-12 pb-20" x-data="{ search: '' }">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <!-- Header -->
        <div class="text-center mb-12">
            <span class="inline-flex items-center rounded-md bg-indigo-50 px-2.5 py-1 text-xs font-medium text-indigo-700 ring-1 ring-inset ring-indigo-700/10 mb-4">
                {{ professions|length }} yrken
            </span>
            <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-5xl mb-4">
                Lönestatistik för alla yrken
            </h1>
            <p class="text-lg text-slate-600 max-w-2xl mx-auto">
                Se vad man tjänar i olika yrken i Sverige 2026. Klicka på ett yrke för att se detaljerad lönestatistik och räkna ut nettolön.
            </p>
        </div>

        <!-- Search/Filter -->
        <!-- Search/Filter -->
        <div class="max-w-xl mx-auto mb-10">
            <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                </div>
                <input type="text" x-model="search" placeholder="Sök yrke (t.ex. Läkare)..." class="block w-full rounded-xl border-0 py-3 pl-10 pr-4 text-slate-900 ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6 bg-white shadow-sm">
            </div>
        </div>

        <!-- Categorized Grid -->
        <div class="space-y-12">
            {% for category in category_order %}
            {% if grouped_professions[category] %}
            <div x-show="!search || $el.querySelectorAll('.profession-card:not([style*=\'display: none\'])').length > 0">
                <h3 class="text-xl font-bold text-slate-800 mb-4 px-1 flex items-center gap-2 border-b border-slate-200 pb-2"
                    x-show="!search || $nextTick(() => true)"> <!-- Hack to trigger update? No, just keep header visible or use simple hiding -->
                    {{ category }}
                    <span class="text-xs font-normal text-slate-500 bg-slate-100 px-2 py-0.5 rounded-full ml-2">
                        {{ grouped_professions[category]|length }}
                    </span>
                </h3>
                
                <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
                    {% for p in grouped_professions[category] %}
                    <a href="/lon/{{ p.slug }}" 
                       class="profession-card group relative flex items-center gap-4 rounded-xl bg-white p-4 shadow-sm ring-1 ring-slate-900/5 hover:shadow-md hover:ring-indigo-600/20 transition-all"
                       x-show="'{{ p.title|lower }}'.includes(search.toLowerCase()) || search === ''">
                        <div class="flex-shrink-0">
                            <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-indigo-50 group-hover:bg-indigo-100 transition-colors">
                                <svg class="h-6 w-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            </div>
                        </div>
                        <div class="min-w-0 flex-1">
                            <h2 class="text-sm font-semibold text-slate-900 group-hover:text-indigo-600 transition-colors">
                                {{ p.title }}
                            </h2>
                            <p class="mt-0.5 text-xs text-slate-500">
                                Median: {{ p.median_salary|number_format(0, ',', ' ') }} kr/mån
                            </p>
                        </div>
                        <div class="flex-shrink-0">
                            <svg class="h-5 w-5 text-slate-400 group-hover:text-indigo-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                            </svg>
                        </div>
                    </a>
                    {% endfor %}
                </div>
            </div>
            {% endif %}
            {% endfor %}
        </div>

        <!-- Stats Summary -->
        <div class="mt-16 bg-white rounded-2xl shadow-sm ring-1 ring-slate-900/5 p-8">
            <h2 class="text-xl font-bold text-slate-900 mb-6 text-center">Lönestatistik i Sverige 2026</h2>
            <div class="grid grid-cols-2 gap-4 sm:grid-cols-4 text-center">
                <div class="p-4">
                    <p class="text-3xl font-bold text-indigo-600">{{ professions|length }}</p>
                    <p class="text-sm text-slate-500 mt-1">Yrken</p>
                </div>
                <div class="p-4">
                    <p class="text-3xl font-bold text-indigo-600">290</p>
                    <p class="text-sm text-slate-500 mt-1">Kommuner</p>
                </div>
                <div class="p-4">
                    <p class="text-3xl font-bold text-indigo-600">32.37%</p>
                    <p class="text-sm text-slate-500 mt-1">Medelskatt</p>
                </div>
            </div>
            <div class="mt-10 pt-8 border-t border-slate-100 flex justify-center">
                <a href="/" class="inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition-colors">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                    </svg>
                    Räkna ut din nettolön
                </a>
            </div>
        </div>

    </div>
</div>
{% endblock %}
