{# ============================================== #}
{# BLOC SCB 2: Historique 10 ans                 #}
{# ============================================== #}
	{% if profession.scb is defined and profession.scb.history|length > 0 and profession.scb.history['2024']|default(0) > 0 %}
		<div class="my-8" x-data="{ view: 'chart' }"> <div class="flex items-center justify-between mb-6">
			<h3 id="loneutveckling-history" class="m-0">Löneutveckling 2014–2024</h3>
			<div class="flex items-center gap-1 bg-slate-100 rounded-lg p-1">
				<button @click="view = 'chart'" :class="{ 'bg-white shadow text-indigo-600': view === 'chart', 'text-slate-500 hover:text-slate-700': view !== 'chart' }" class="px-3 py-1 text-xs font-medium rounded-md transition-all">Graf</button>
				<button @click="view = 'table'" :class="{ 'bg-white shadow text-indigo-600': view === 'table', 'text-slate-500 hover:text-slate-700': view !== 'table' }" class="px-3 py-1 text-xs font-medium rounded-md transition-all">Tabell</button>
			</div>
		</div>

		<div x-show="view === 'chart'" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" class="h-64">
			<canvas id="salaryHistoryChart"></canvas>
		</div>

		<div x-show="view === 'table'" x-cloak x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" class="overflow-hidden bg-white shadow-sm ring-1 ring-slate-900/5 rounded-lg">
			<table class="min-w-full divide-y divide-slate-200 mt-0">
				<thead class="bg-slate-50">
					<tr>
						<th scope="col" class="px-3 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">År</th>
						<th scope="col" class="px-3 py-3 text-right text-xs font-medium text-slate-500 uppercase tracking-wider">Totalt</th>
						{% if profession.scb.history_men %}
							<th scope="col" class="px-3 py-3 text-right text-xs font-medium text-slate-500 uppercase tracking-wider">Män</th>
						{% endif %}
						{% if profession.scb.history_women %}
							<th scope="col" class="px-3 py-3 text-right text-xs font-medium text-slate-500 uppercase tracking-wider">Kvinnor</th>
						{% endif %}
					</tr>
				</thead>
				<tbody class="divide-y divide-slate-200 bg-white">
					{% for year, salary in profession.scb.history|reverse(true) %}
						<tr class="hover:bg-slate-50 transition-colors">
							<td class="whitespace-nowrap px-3 py-3 text-sm font-medium text-slate-900">{{ year }}</td>
							<td class="whitespace-nowrap px-3 py-3 text-sm text-right text-slate-600">{{ salary|number_format(0, ' ', ' ') }}
								kr</td>
							{% if profession.scb.history_men %}
								<td class="whitespace-nowrap px-3 py-3 text-sm text-right text-blue-600">{{ profession.scb.history_men[year]|default(0)|number_format(0, ' ', ' ') }}
									kr</td>
							{% endif %}
							{% if profession.scb.history_women %}
								<td class="whitespace-nowrap px-3 py-3 text-sm text-right text-pink-600">{{ profession.scb.history_women[year]|default(0)|number_format(0, ' ', ' ') }}
									kr</td>
							{% endif %}
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>

		<script>
			document.addEventListener('DOMContentLoaded', function () {
const ctx = document.getElementById('salaryHistoryChart');
if (ctx) {
new Chart(ctx, {
type: 'line',
data: {
labels: [{% for year, salary in profession.scb.history %}'{{ year }}'{% if not loop.last %},{% endif %}{% endfor %}],
datasets: [{% if profession.scb.history_men is not defined or profession.scb.history_men|length == 0 %}{
label: 'Totalt',
data: [{% for year, salary in profession.scb.history %}{{ salary }}{% if not loop.last %},{% endif %}{% endfor %}],
borderColor: 'rgb(79, 70, 229)',
backgroundColor: 'rgba(79, 70, 229, 0.1)',
fill: true,
tension: 0.3,
pointBackgroundColor: 'rgb(79, 70, 229)',
pointBorderColor: '#fff',
pointBorderWidth: 2,
pointRadius: 4
},{% endif %}{% if profession.scb.history_men %}{
label: 'Män',
data: [{% for year, salary in profession.scb.history_men %}{{ salary }}{% if not loop.last %},{% endif %}{% endfor %}],
borderColor: 'rgb(59, 130, 246)',
backgroundColor: 'rgba(59, 130, 246, 0.05)',
fill: false,
tension: 0.3,
pointBackgroundColor: 'rgb(59, 130, 246)',
pointBorderColor: '#fff',
pointBorderWidth: 2,
pointRadius: 4
},{% endif %}{% if profession.scb.history_women %}{
label: 'Kvinnor',
data: [{% for year, salary in profession.scb.history_women %}{{ salary }}{% if not loop.last %},{% endif %}{% endfor %}],
borderColor: 'rgb(236, 72, 153)',
backgroundColor: 'rgba(236, 72, 153, 0.05)',
fill: false,
tension: 0.3,
pointBackgroundColor: 'rgb(236, 72, 153)',
pointBorderColor: '#fff',
pointBorderWidth: 2,
pointRadius: 4
}
{% endif %}]
},
options: {
responsive: true,
maintainAspectRatio: false,
plugins: {
legend: {
display: true,
position: 'top',
labels: {
usePointStyle: true,
boxWidth: 8
}
},
tooltip: {
callbacks: {
label: function (context) {
return context.dataset.label + ': ' + context.parsed.y.toLocaleString('sv-SE') + ' kr';
}
}
}
},
scales: {
y: {
beginAtZero: false,
ticks: {
callback: function (value) {
return value.toLocaleString('sv-SE') + ' kr';
}
}
}
}
}
});
}
});
		</script>

		{% if profession.scb.history_men and profession.scb.history_women %}
			{% set start_year = '2014' %}
			{% set end_year = '2024' %}

			{% set men_start = profession.scb.history_men[start_year]|default(0) %}
			{% set men_end = profession.scb.history_men[end_year]|default(0) %}
			{% set women_start = profession.scb.history_women[start_year]|default(0) %}
			{% set women_end = profession.scb.history_women[end_year]|default(0) %}

			{% if men_start > 0 and women_start > 0 and men_end > 0 %}
				{# Advanced Analysis Block #}
				{% set men_growth = ((men_end - men_start) / men_start * 100) %}
				{% set women_growth = ((women_end - women_start) / women_start * 100) %}

				{% set gap_start = ((men_start - women_start) / men_start * 100) %}
				{% set gap_end = ((men_end - women_end) / men_end * 100) %}
				{% set gap_change = gap_end - gap_start %}

				<div class="mt-6 p-5 bg-indigo-50 border-l-4 border-indigo-500 rounded-r-xl">
					<h4 class="text-sm font-bold text-indigo-900 uppercase tracking-wide mb-3 flex items-center gap-2">
						<svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewbox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
						</svg>
						Löneanalys: 10 års utveckling
					</h4>
					<div class="space-y-3 text-slate-700 text-sm leading-relaxed">
						<p>
							Under perioden
							{{ start_year }}-{{ end_year }}
							har lönen för
							{{ profession.title|lower }}
							ökat totalt med
							<strong>{{ (((profession.scb.history[end_year] - profession.scb.history[start_year]) / profession.scb.history[start_year]) * 100)|round(1) }}%</strong>.
						</p>

						<div class="grid grid-cols-2 gap-4 my-3">
							<div class="bg-white p-3 rounded border border-indigo-100">
								<span class="block text-xs text-slate-500 uppercase tracking-wider mb-1">Män</span>
								<div class="flex items-baseline gap-2">
									<span class="text-lg font-bold text-blue-600">+{{ men_growth|round(1) }}%</span>
									<span class="text-xs text-slate-400">({{ men_start|number_format(0, ' ', ' ') }}
										→
										{{ men_end|number_format(0, ' ', ' ') }})</span>
								</div>
							</div>
							<div class="bg-white p-3 rounded border border-indigo-100">
								<span class="block text-xs text-slate-500 uppercase tracking-wider mb-1">Kvinnor</span>
								<div class="flex items-baseline gap-2">
									<span class="text-lg font-bold text-pink-600">+{{ women_growth|round(1) }}%</span>
									<span class="text-xs text-slate-400">({{ women_start|number_format(0, ' ', ' ') }}
										→
										{{ women_end|number_format(0, ' ', ' ') }})</span>
								</div>
							</div>
						</div>

						<p>
							<strong>Analys av lönegapet:</strong>
							{% if gap_change < -0.5 %}
								Utvecklingen visar att kvinnors löner ökar snabbare än männens ({{ women_growth|round(1) }}% vs
								{{ men_growth|round(1) }}%),
																																																																								                                    vilket har minskat lönegapet från
								{{ gap_start|round(1) }}% år
								{{ start_year }}
								till
								{{ gap_end|round(1) }}% år
								{{ end_year }}.
							{% elseif gap_change > 0.5 %}
								Tyvärr har löneskillnaden ökat något under perioden, då männens löner haft en starkare utveckling ({{ men_growth|round(1) }}%)
																																																																								                                    jämfört med kvinnornas ({{ women_growth|round(1) }}%).
							{% else %}
								Löneskillnaden har varit relativt konstant och följer den generella löneutvecklingen för yrket.
							{% endif %}
						</p>
					</div>
				</div>
			{% endif %}

			{# Fallback for professions without gender history #}
		{% elseif profession.scb.evolution_10y_percent %}
			<div class="mt-6 p-4 bg-emerald-50 rounded-xl border border-emerald-100">
				<p class="text-sm text-emerald-800">
					<strong>+{{ profession.scb.evolution_10y_percent }}%</strong>
					löneutveckling på 10 år
																																													                    (från
					{{ profession.scb.history['2014']|number_format(0, ' ', ' ') }}
					kr till
					{{ profession.scb.salary_total|number_format(0, ' ', ' ') }}
					kr)
				</p>
			</div>
		{% endif %}
	</div>


	<div class="flex justify-center mb-12">
		<button onclick="document.getElementById('calculator').scrollIntoView({behavior: 'smooth'})" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full border-2 border-indigo-600 text-indigo-600 font-bold hover:bg-indigo-50 transition-colors">
			<svg class="w-4 h-4" fill="none" stroke="currentColor" viewbox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
			</svg>
			Beräkna nettolön nu
		</button>
	</div>
{% endif %}
