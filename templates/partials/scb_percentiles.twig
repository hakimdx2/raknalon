{# Percentile Distribution Widget #}
{% if profession.scb.percentiles and profession.scb.percentiles.p10 > 0 %}
	<div class="my-10">
		<h3 class="text-2xl font-bold text-slate-900 mb-6" id="lonefordelning">
			Lönefördelning
		</h3>

		<p class="text-lg text-slate-600 mb-8 leading-relaxed">
			Så fördelas lönerna för
			{{ profession.title }}
			i Sverige. Siffrorna visar hur stor andel som tjänar under respektive nivå.
		</p>

		{# Visual bars representing distribution #}
		<div
			class="space-y-6 mb-10">
			{# P90 - Top 10% #}
			<div class="relative">
				<div class="flex items-center justify-between mb-2">
					<span class="text-sm font-medium text-slate-700">Topp 10% tjänar över</span>
					<span class="text-base font-bold text-emerald-600">{{ profession.scb.percentiles.p90|number_format(0, ',', ' ') }}
						kr</span>
				</div>
				<div class="w-full bg-slate-100 rounded-full h-4 overflow-hidden">
					<div class="bg-gradient-to-r from-emerald-400 to-emerald-500 h-full rounded-full transition-all duration-500" style="width: 90%"></div>
				</div>
			</div>

			{# P75 - Top 25% #}
			<div class="relative">
				<div class="flex items-center justify-between mb-2">
					<span class="text-sm font-medium text-slate-700">Topp 25% tjänar över</span>
					<span class="text-base font-bold text-teal-600">{{ profession.scb.percentiles.p75|number_format(0, ',', ' ') }}
						kr</span>
				</div>
				<div class="w-full bg-slate-100 rounded-full h-4 overflow-hidden">
					<div class="bg-gradient-to-r from-teal-400 to-teal-500 h-full rounded-full transition-all duration-500" style="width: 75%"></div>
				</div>
			</div>

			{# P50 - Median #}
			<div class="relative">
				<div class="flex items-center justify-between mb-2">
					<span class="text-sm font-medium text-slate-700">Medianlön (50%)</span>
					<span class="text-base font-bold text-indigo-600">{{ profession.scb.percentiles.p50|number_format(0, ',', ' ') }}
						kr</span>
				</div>
				<div class="w-full bg-slate-100 rounded-full h-4 overflow-hidden">
					<div class="bg-gradient-to-r from-indigo-400 to-indigo-500 h-full rounded-full transition-all duration-500" style="width: 50%"></div>
				</div>
			</div>

			{# P25 - Bottom 25% #}
			<div class="relative">
				<div class="flex items-center justify-between mb-2">
					<span class="text-sm font-medium text-slate-700">25% tjänar under</span>
					<span class="text-base font-bold text-amber-600">{{ profession.scb.percentiles.p25|number_format(0, ',', ' ') }}
						kr</span>
				</div>
				<div class="w-full bg-slate-100 rounded-full h-4 overflow-hidden">
					<div class="bg-gradient-to-r from-amber-400 to-amber-500 h-full rounded-full transition-all duration-500" style="width: 25%"></div>
				</div>
			</div>

			{# P10 - Bottom 10% #}
			<div class="relative">
				<div class="flex items-center justify-between mb-2">
					<span class="text-sm font-medium text-slate-700">10% tjänar under</span>
					<span class="text-base font-bold text-rose-600">{{ profession.scb.percentiles.p10|number_format(0, ',', ' ') }}
						kr</span>
				</div>
				<div class="w-full bg-slate-100 rounded-full h-4 overflow-hidden">
					<div class="bg-gradient-to-r from-rose-400 to-rose-500 h-full rounded-full transition-all duration-500" style="width: 10%"></div>
				</div>
			</div>
		</div>

		{# Analysis Box - Consistency with scb_salary_by_age.twig #}
		<div class="p-5 bg-indigo-50 border-l-4 border-indigo-500 rounded-r-xl">
			<h4 class="text-sm font-bold text-indigo-900 uppercase tracking-wide mb-3 flex items-center gap-2">
				<svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewbox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
				</svg>
				Löneanalys
				{{ profession.scb.year }}: Lönespridning
			</h4>
			<div class="text-slate-700 text-sm leading-relaxed">
				<p>
					{% set range = profession.scb.percentiles.p90 - profession.scb.percentiles.p10 %}
					Löneskillnaden mellan de 10% lägst och högst betalda är
					<strong>{{ range|number_format(0, ',', ' ') }}
						kr</strong>
					per månad.
					{% if range > 20000 %}
						Detta visar på stor variation – erfarenhet, specialisering och arbetsplats har stor betydelse för din slutgiltiga lön.
					{% elseif range > 10000 %}
						Lönen varierar måttligt beroende på din erfarenhet och vilken sektor du arbetar inom.
					{% else %}
						Lönerna är relativt jämna inom yrket, vilket innebär att ingångslön och slutlön inte skiljer sig markant åt.
					{% endif %}
				</p>
			</div>
		</div>
	</div>
{% endif %}
