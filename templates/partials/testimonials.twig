{# Section Témoignages - Histoires émouvantes de professionnels #}

{% if profession.testimonials is defined and profession.testimonials is not empty %}
	<div class="mt-16 border-t border-slate-200 pt-10" id="testimonials-section">
		<div class="mb-8">
			<h2 class="text-xl font-bold text-slate-900">Berättelser från verkligheten</h2>
			<p class="mt-1 text-sm text-slate-500">Verkliga upplevelser från
				{{ profession.title|lower }}
				som delar sina karriärresor.</p>
		</div>

		<div class="space-y-8">
			{% for testimonial in profession.testimonials %}
				<div
					class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-indigo-50 via-white to-purple-50 p-8 shadow-lg ring-1 ring-indigo-100">
					{# Decorative quote mark #}
					<div class="absolute -top-4 -left-4 text-9xl font-serif text-indigo-200 opacity-50 select-none">"</div>

					{# Rating stars #}
					{% if testimonial.rating is defined %}
						<div class="flex items-center gap-1 mb-4">
							{% for i in 1..5 %}
								<svg class="w-5 h-5 {{ i <= testimonial.rating ? 'text-amber-400' : 'text-slate-300' }}" fill="currentColor" viewbox="0 0 20 20">
									<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
								</svg>
							{% endfor %}
						</div>
					{% endif %}

					{# Title #}
					{% if testimonial.title is defined %}
						<h3 class="text-lg font-bold text-indigo-900 mb-4">{{ testimonial.title }}</h3>
					{% endif %}

					{# Content - with line breaks #}
					<div class="relative z-10 text-slate-700 leading-relaxed space-y-4">
						{% for paragraph in testimonial.content|split('\\n\\n') %}
							<p class="text-base">{{ paragraph|replace({'\\n': '<br>'})|raw }}</p>
						{% endfor %}
					</div>

					{# Author info #}
					<div class="mt-6 pt-6 border-t border-indigo-100 flex items-center gap-4">
						<div class="flex-shrink-0">
							<div class="h-14 w-14 rounded-full bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-white text-xl font-bold shadow-lg">
								{{ testimonial.name|first }}
							</div>
						</div>
						<div>
							<div class="flex items-center gap-2">
								<p class="font-semibold text-slate-900">{{ testimonial.name }}</p>
								{% if testimonial.verified is defined and testimonial.verified %}
									<span class="inline-flex items-center gap-1 rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-medium text-emerald-700">
										<svg class="w-3 h-3" fill="currentColor" viewbox="0 0 20 20">
											<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
										</svg>
										Verifierad
									</span>
								{% endif %}
							</div>
							<p class="text-sm text-slate-500">
								{% if testimonial.age is defined %}
									{{ testimonial.age }}
									år
								{% endif %}
								{% if testimonial.location is defined %}
									•
									{{ testimonial.location }}
								{% endif %}
								{% if testimonial.years_in_profession is defined %}
									•
									{{ testimonial.years_in_profession }}
									år i yrket
								{% endif %}
							</p>
						</div>
					</div>
				</div>
			{% endfor %}
		</div>
	</div>
{% endif %}
